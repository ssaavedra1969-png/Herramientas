# Firebase Admin SDK
# Opción 1: Pegar el JSON COMPLETO en una sola línea
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"engaged-card-450213-d7",...}

# Opción 2: Ruta al archivo JSON (alternativa a pegar el JSON)
# FIREBASE_SERVICE_ACCOUNT_PATH=./engaged-card-450213-d7-firebase-adminsdk-fbsvc-a956702c95.json

# Firebase Client SDK (copiar de Firebase Console → Configuración de la app web)
