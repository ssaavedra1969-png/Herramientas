<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Google Sign-In - Grupo Falpat SRL</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #0B0E17; color: #F1F3F8; font-family: system-ui, sans-serif; }
    .spinner { width: 40px; height: 40px; border: 3px solid rgba(255,107,53,0.2); border-top-color: #FF6B35; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center">
  <div class="text-center">
    <div class="spinner mx-auto mb-4"></div>
    <p class="text-[#8E94A8] text-sm" id="status">Iniciando sesión con Google...</p>
  </div>
  <script>
    const FIREBASE_CONFIG = <%- JSON.stringify(clientConfig) %>;
  </script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
  <script>
    (async function() {
      const statusEl = document.getElementById('status');
      try {
        firebase.initializeApp(FIREBASE_CONFIG);
        const auth = firebase.auth();
        const hash = window.location.hash;

        // If there's a hash, we're back from the Firebase handler redirect
        if (hash && hash.length > 5) {
          statusEl.textContent = 'Procesando inicio de sesión...';

          // Try Firebase SDK getRedirectResult first
          let googleIdToken = null;
          try {
            const redirectResult = await auth.getRedirectResult();
            if (redirectResult && redirectResult.credential) {
              const cred = redirectResult.credential;
              googleIdToken = cred.idToken || cred.accessToken;
            }
          } catch (e) {
            console.log('getRedirectResult returned:', e.code || e.message);
          }

          // If getRedirectResult didn't work, parse the hash manually
          if (!googleIdToken && hash.includes('firebase-auth-redirect')) {
            try {
              const raw = hash.split('firebase-auth-redirect=')[1].split('&')[0];
              const decoded = decodeURIComponent(raw);
              const json = JSON.parse(atob(decoded.replace(/-/g, '+').replace(/_/g, '/')));
              console.log('Redirect data:', json);
              // Try different formats
              if (json.response) {
                googleIdToken = json.response.oauthIdToken || json.response.oauthAccessToken || json.response.idToken;
              }
              if (!googleIdToken && json.oauthIdToken) googleIdToken = json.oauthIdToken;
              if (!googleIdToken && json.postBody) {
                const match = json.postBody.match(/id_token=([^&]+)/);
                if (match) googleIdToken = match[1];
              }
            } catch (e) {
              console.error('Manual hash parse error:', e);
            }
          }

          if (googleIdToken) {
            const credential = firebase.auth.GoogleAuthProvider.credential(googleIdToken);
            const result = await auth.signInWithCredential(credential);
            const firebaseToken = await result.user.getIdToken();
            const sessionRes = await fetch('/api/auth/session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ idToken: firebaseToken })
            });
            if (!sessionRes.ok) throw new Error('Error al crear sesión');
            window.location.href = '/dashboard';
          } else {
            window.location.href = '/login?error=No+se+recibieron+credenciales+de+Google';
          }
          return;
        }

        // No hash → initiate the redirect sign-in flow
        statusEl.textContent = 'Redirigiendo a Google...';
        const googleProvider = new firebase.auth.GoogleAuthProvider();
        googleProvider.setCustomParameters({ prompt: 'select_account' });
        await auth.signInWithRedirect(googleProvider);
        // signInWithRedirect redirects the page immediately, so we never reach here
      } catch (e) {
        console.error('Google init error:', e);
        window.location.href = '/login?error=' + encodeURIComponent(e.message || 'Error al iniciar sesión con Google');
      }
    })();
  </script>
</body>
</html>