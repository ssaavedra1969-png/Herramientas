<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Google Sign-In - Grupo Falpat SRL</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #0B0E17; color: #F1F3F8; font-family: monospace; }
    .spinner { width: 40px; height: 40px; border: 3px solid rgba(255,107,53,0.2); border-top-color: #FF6B35; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    #debug { text-align: left; font-size: 12px; word-break: break-all; max-width: 900px; margin: 20px auto; }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="text-center w-full">
    <div id="loading">
      <div class="spinner mx-auto mb-4"></div>
      <p class="text-[#8E94A8] text-sm" id="status">Iniciando sesión con Google...</p>
    </div>
    <pre id="debug" class="hidden bg-[#0a0e17] border border-[#FF6B35]/20 rounded-lg p-4 text-left text-xs overflow-auto max-h-[80vh]"></pre>
  </div>
  <script>
    function showDebug(obj) {
      document.getElementById('loading').style.display = 'none';
      const el = document.getElementById('debug');
      el.classList.remove('hidden');
      el.textContent = typeof obj === 'string' ? obj : JSON.stringify(obj, null, 2);
    }

    function hasPendingRedirect() {
      for (let i = 0; i < sessionStorage.length; i++) {
        const key = sessionStorage.key(i);
        if (key && key.includes('firebase:') && key.includes('redirect')) return true;
      }
      return false;
    }

    const FIREBASE_CONFIG = <%- JSON.stringify(clientConfig) %>;
  </script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
  <script>
    (async function() {
      try {
        firebase.initializeApp(FIREBASE_CONFIG);
        const auth = firebase.auth();
        const hash = window.location.hash || '';
        const fullUrl = window.location.href;
        const referrer = document.referrer || '';
        const fromFirebase = referrer.includes('firebaseapp.com') || referrer.includes('google.com');
        const pending = hasPendingRedirect();

        // 1. Hash present → process redirect result
        if (hash && hash.length > 5) {
          // Try getRedirectResult first
          try {
            const redirectResult = await auth.getRedirectResult();
            if (redirectResult && redirectResult.user) {
              const firebaseToken = await redirectResult.user.getIdToken();
              const sessionRes = await fetch('/api/auth/session', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ idToken: firebaseToken })
              });
              if (sessionRes.ok) { window.location.href = '/dashboard'; return; }
              throw new Error('Session creation failed');
            }
          } catch (e) { /* fall through to manual parse */ }

          // Manual parse: firebase-auth-redirect=...
          const raw = hash.split('firebase-auth-redirect=')[1]?.split('&')[0];
          if (raw) {
            try {
              const decoded = decodeURIComponent(raw);
              const base64 = decoded.replace(/-/g, '+').replace(/_/g, '/');
              const jsonStr = atob(base64);
              const json = JSON.parse(jsonStr);
              let googleIdToken = json.response?.oauthIdToken
                || json.response?.oauthAccessToken
                || json.response?.idToken
                || json.oauthIdToken;
              if (!googleIdToken && json.postBody) {
                const m = json.postBody.match(/id_token=([^&]+)/);
                if (m) googleIdToken = m[1];
              }
              if (googleIdToken) {
                const credential = firebase.auth.GoogleAuthProvider.credential(googleIdToken);
                const result = await auth.signInWithCredential(credential);
                const firebaseToken = await result.user.getIdToken();
                const sessionRes = await fetch('/api/auth/session', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ idToken: firebaseToken })
                });
                if (!sessionRes.ok) throw new Error('Session creation failed');
                window.location.href = '/dashboard';
                return;
              }
            } catch (e) { /* fall through to debug */ }
          }

          // Also try parsing as query params
          const m = fullUrl.match(/[?&]code=([^&]+)/);
          if (m) {
            showDebug({ step: 'OAuth code in URL (no hash)', code: m[1], fullUrl });
            return;
          }

          showDebug({ step: 'Unrecognized hash format', hash, fullUrl });
          return;
        }

        // 2. No hash but returned from redirect (pending state or referrer)
        if (pending || fromFirebase) {
          try {
            const result = await auth.getRedirectResult();
            if (result && result.user) {
              const token = await result.user.getIdToken();
              const sessionRes = await fetch('/api/auth/session', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ idToken: token })
              });
              if (sessionRes.ok) { window.location.href = '/dashboard'; return; }
            }
          } catch (e) { /* fall through to debug */ }
          showDebug({ step: 'Redirect returned but no result',
            fullUrl, referrer, pending,
            sessionStorageKeys: Object.keys(sessionStorage).filter(k => k.includes('firebase:')) });
          return;
        }

        // 3. Fresh load → initiate the redirect
        document.getElementById('status').textContent = 'Redirigiendo a Google...';
        const googleProvider = new firebase.auth.GoogleAuthProvider();
        googleProvider.setCustomParameters({ prompt: 'select_account' });
        await auth.signInWithRedirect(googleProvider);
      } catch (e) {
        showDebug({ step: 'Fatal error', error: e.message });
      }
    })();
  </script>
</body>
</html>