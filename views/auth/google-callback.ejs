<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verificando... - Grupo Falpat SRL</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #0A0A1A; color: #F1F3F8; font-family: system-ui, sans-serif; }
    .spinner { width: 40px; height: 40px; border: 3px solid rgba(255,107,53,0.2); border-top-color: #6C3CE1; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center">
  <div class="text-center">
    <div class="spinner mx-auto mb-4"></div>
    <p class="text-[#8E94A8] text-sm">Verificando inicio de sesión...</p>
  </div>
  <script>
    const FIREBASE_CONFIG = <%- JSON.stringify(clientConfig) %>;
  </script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
  <script>
    (async function() {
      try {
        firebase.initializeApp(FIREBASE_CONFIG);
        const auth = firebase.auth();

        const hash = window.location.hash;
        const params = new URLSearchParams(hash.substring(1));
        const idToken = params.get('id_token');

        if (!idToken) {
          window.location.href = '/login?error=No+se+recibieron+credenciales+de+Google';
          return;
        }

        const credential = firebase.auth.GoogleAuthProvider.credential(idToken);
        const result = await auth.signInWithCredential(credential);

        const firebaseToken = await result.user.getIdToken();

        const sessionRes = await fetch('/api/auth/session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken: firebaseToken })
        });

        if (!sessionRes.ok) {
          const errData = await sessionRes.json().catch(() => ({}));
          throw new Error(errData.error || 'Error al crear sesión');
        }

        window.location.href = '/dashboard';
      } catch (e) {
        console.error('Google login error:', e);
        window.location.href = '/login?error=' + encodeURIComponent(e.message || 'Error al iniciar sesión con Google');
      }
    })();
  </script>
</body>
</html>