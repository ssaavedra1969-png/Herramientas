<script>
  const FIREBASE_CONFIG = <%- JSON.stringify(clientConfig) %>;
  window.__DEV_READ_ONLY = <%- clientConfig.devReadOnly ? 'true' : 'false' %>;
  firebase.initializeApp(FIREBASE_CONFIG);
  window.__SERVER_USER_DATA = <%- JSON.stringify(currentUserData?.role ? { role: currentUserData.role, displayName: currentUserData.displayName } : null) %>;
</script>
<% if (clientConfig.devReadOnly) { %>
<script src="/js/dev-readonly.js?v=<%= Date.now() %>"></script>
<% } %>
<script src="/js/auth-client.js?v=<%= Date.now() %>"></script>
</body>
</html>
