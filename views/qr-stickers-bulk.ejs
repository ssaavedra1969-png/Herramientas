<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Impresión Masiva de Stickers QR — Grupo Falpat</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <style>
    * { box-sizing: border-box; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
    body { background: #1a1a2e; font-family: 'Segoe UI', Arial, sans-serif; margin: 0; padding: 20px; }
    .toolbar { max-width: 1100px; margin: 0 auto 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .toolbar h1 { color: #F1F3F8; font-size: 22px; font-weight: 700; margin: 0; }
    .toolbar p { color: #8E94A8; font-size: 13px; margin: 2px 0 0; }
    .btn-print { background: #6C3CE1; color: #fff; padding: 10px 24px; border: none; border-radius: 10px; font-size: 14px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: background 0.15s; }
    .btn-print:hover { background: #5a2dc0; }
    .btn-back { background: rgba(255,255,255,0.1); color: #F1F3F8; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; transition: background 0.15s; }
    .btn-back:hover { background: rgba(255,255,255,0.15); }
    .info-bar { background: rgba(255,255,255,0.06); border: 1px solid rgba(108,60,225,0.15); border-radius: 10px; padding: 10px 16px; color: #8E94A8; font-size: 12px; max-width: 1100px; margin: 0 auto 16px; display: flex; gap: 20px; flex-wrap: wrap; }
    .info-bar span { display: flex; align-items: center; gap: 4px; }
    .info-bar strong { color: #F1F3F8; }

    .sticker-grid {
      display: grid;
      grid-template-columns: repeat(2, 100mm);
      grid-auto-rows: 70mm;
      gap: 4mm;
      justify-content: center;
      max-width: 1100px;
      margin: 0 auto;
    }
    .sticker {
      width: 100mm;
      height: 70mm;
      background: #fff;
      border-radius: 4mm;
      overflow: hidden;
      position: relative;
      page-break-inside: avoid;
      break-inside: avoid;
    }
    .sticker-header {
      background: linear-gradient(135deg, #6C3CE1, #00D4FF);
      padding: 3mm 4mm;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .sticker-body {
      padding: 3mm 4mm;
      display: flex;
      gap: 4mm;
      align-items: center;
    }
    .sticker-qr { flex-shrink: 0; }
    .sticker-info { flex: 1; color: #1a1a2e; }
    .sticker-patente { font-size: 20pt; font-weight: 900; color: #1a1a2e; letter-spacing: 1px; line-height: 1; }
    .sticker-detail { font-size: 7pt; color: #555; line-height: 1.4; }
    .sticker-footer {
      background: #f0f0f5;
      padding: 1.5mm 4mm;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 0.5px solid #ddd;
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
    }
    .page-separator { display: none; }

    @media print {
      body { background: #fff !important; padding: 0; margin: 0; }
      .no-print { display: none !important; }
      .sticker { box-shadow: none; }
      .sticker-grid { gap: 2mm; }
      .page-separator { display: block; page-break-after: always; break-after: page; height: 0; }
    }
  </style>
</head>
<body>
  <div class="no-print">
    <div class="toolbar">
      <div>
        <h1>Impresión Masiva de Stickers QR</h1>
        <p>Se imprimirán todos los stickers de la flota</p>
      </div>
      <div style="display:flex;gap:10px;">
        <button onclick="window.print()" class="btn-print">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
          Imprimir Todo (<%= vehicles.length %> stickers)
        </button>
        <a href="/dashboard" class="btn-back">Volver</a>
      </div>
    </div>
    <div class="info-bar">
      <span><strong><%= vehicles.length %></strong> stickers</span>
      <span><strong>2 por fila</strong> — A4 horizontal</span>
      <span>Sticker: <strong>100mm × 70mm</strong></span>
      <span><strong>~<%= Math.ceil(vehicles.length / 4) %></strong> páginas</span>
    </div>
  </div>

  <div class="sticker-grid" id="sticker-grid">
    <% vehicles.forEach((v, i) => { %>
      <% if (i > 0 && i % 4 === 0) { %><div class="page-separator"></div><% } %>
      <div class="sticker">
        <div class="sticker-header">
          <div style="display:flex;align-items:center;gap:2mm;">
            <div style="background:#fff;border-radius:2mm;width:8mm;height:8mm;display:flex;align-items:center;justify-content:center;">
              <span style="color:#6C3CE1;font-size:9pt;font-weight:900;">GF</span>
            </div>
            <div style="display:flex;flex-direction:column;">
              <span style="color:#fff;font-size:8pt;font-weight:700;letter-spacing:0.5px;">GRUPO FALPAT SRL</span>
              <span style="color:rgba(255,255,255,0.8);font-size:6pt;">Control de Mantenimiento</span>
            </div>
          </div>
          <div style="text-align:right;">
            <span style="color:rgba(255,255,255,0.6);font-size:5.5pt;display:block;">Interno</span>
            <span style="color:#fff;font-size:13pt;font-weight:900;letter-spacing:1px;line-height:1;"><%= v.interno || '—' %></span>
          </div>
        </div>

        <div class="sticker-body">
          <div class="sticker-qr">
            <div id="qr-<%= i %>"></div>
          </div>
          <div class="sticker-info">
            <div class="sticker-patente"><%= v.patente || '—' %></div>
            <div style="font-size:8pt;font-weight:700;color:#1a1a2e;margin-top:1.5mm;"><%= v.marca || '' %> <%= v.modelo || '' %></div>
          </div>
        </div>

        <div class="sticker-footer">
          <span style="font-size:6.5pt;color:#333;font-weight:600;font-family:'Segoe UI',Arial,sans-serif;"><%= v.marca || '' %> <%= v.modelo || '' %></span>
          <span style="font-size:6pt;color:#888;font-family:'Segoe UI',Arial,sans-serif;"><%= v.empresa || '' %></span>
        </div>
      </div>
    <% }) %>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const vehicles = <%- JSON.stringify(vehicles) %>;
      vehicles.forEach((v, i) => {
        const el = document.getElementById('qr-' + i);
        if (el) {
          new QRCode(el, {
            text: v.qrUrl,
            width: 130,
            height: 130,
            colorDark: '#000000',
            colorLight: '#ffffff',
            correctLevel: QRCode.CorrectLevel.H
          });
        }
      });
    });
  </script>
</body>
</html>
