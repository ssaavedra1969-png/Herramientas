          <div class="text-[10px] font-bold text-[#5C6378] uppercase tracking-widest mb-2 border-b border-[#6C3CE1]/5 pb-1">Documentación</div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-1.5">
            <label class="flex items-center gap-2 text-sm text-[#F1F3F8] cursor-pointer hover:text-[#A78BFA] transition-colors py-0.5">
