<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'vehicles' }) %>
  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#6C3CE1]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#6C3CE1] to-[#00D4FF] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>
    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <!-- Header: Título + Contador + Acciones -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-3 mb-4">
        <div class="flex items-center gap-2">
          <h1 class="text-xl sm:text-2xl font-bold text-gradient-primary">Vehículos</h1>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-bold bg-[#6C3CE1]/15 text-[#A78BFA] border border-[#6C3CE1]/20">
            <span id="total-vehicles">0</span>
          </span>
        </div>
        <div class="flex gap-1.5 sm:gap-2 flex-wrap">
          <a href="/vehicle/scan" class="btn-secondary text-xs sm:text-sm flex items-center gap-1 px-2.5 sm:px-4 py-1.5 sm:py-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h.01M12 12h-.01M12 12h.01M12 12h-.01M12 12h.01M12 12h-.01M8 4h.01M16 4h.01M4 8h.01M4 16h.01M20 8h.01M20 16h.01"/></svg>
            <span class="sm:inline">Escáner</span>
          </a>
          <button onclick="openExportModal()" class="btn-secondary text-xs sm:text-sm flex items-center gap-1 px-2.5 sm:px-4 py-1.5 sm:py-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <span class="sm:inline">Exportar</span>
          </button>
          <% if (currentUserData?.role === 'Admin') { %>
          <div class="relative" id="import-dropdown">
            <button onclick="toggleImportMenu()" class="btn-primary text-xs sm:text-sm flex items-center gap-1 px-2.5 sm:px-4 py-1.5 sm:py-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg>
              <span class="hidden sm:inline">Importar</span>
            </button>
            <div id="import-menu" class="hidden absolute right-0 mt-2 w-48 glass-card rounded-lg shadow-xl border border-[#6C3CE1]/10 z-10">
              <button onclick="openCsvImport()" class="w-full text-left px-4 py-3 text-sm text-[#F1F3F8] hover:bg-[#6C3CE1]/10 flex items-center gap-2 rounded-lg">
                <svg class="w-4 h-4 text-[#8E94A8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg> Desde CSV
              </button>
            </div>
          </div>
          <button onclick="openVehicleModal()" class="btn-primary text-xs sm:text-sm flex items-center gap-1 px-2.5 sm:px-4 py-1.5 sm:py-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Nuevo
          </button>
          <% } %>
        </div>
      </div>

      <!-- Search + Controls Bar -->
      <div class="glass-card rounded-xl overflow-hidden mb-4">
        <div class="flex items-center gap-2 p-2 sm:p-3 search-controls">
          <!-- Search input -->
          <div class="relative flex-1 min-w-0">
            <svg class="absolute left-2.5 sm:left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#5C6378]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" id="search-vehiculo" placeholder="Buscar..." class="w-full pl-8 sm:pl-9 pr-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/15 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon transition-all focus:border-[#6C3CE1]/50">
          </div>
          <!-- Filter toggle -->
          <button id="filter-toggle-btn" onclick="toggleFilters()" class="px-2 sm:px-3 py-2 text-xs font-medium text-[#8E94A8] hover:text-[#F1F3F8] hover:bg-[#6C3CE1]/10 rounded-lg transition-colors flex items-center gap-1 border border-transparent hover:border-[#6C3CE1]/20 shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
            <span class="hidden sm:inline">Filtros</span>
            <span id="active-filters-count" class="hidden px-1.5 py-0.5 bg-[#6C3CE1]/30 text-[#A78BFA] rounded-full text-[10px] font-bold leading-none"></span>
          </button>
          <!-- Divider -->
          <div class="w-px h-5 bg-[#6C3CE1]/10 shrink-0"></div>
          <!-- View toggle -->
          <div class="flex rounded-lg overflow-hidden border border-[#6C3CE1]/15 bg-[#0A0A1A]/40 shrink-0">
            <button id="view-table-btn" onclick="setViewMode('table')" class="px-2 py-1.5 text-xs font-medium text-[#8E94A8] hover:text-[#F1F3F8] hover:bg-[#6C3CE1]/10 transition-colors flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18M3 6h18M3 18h18"/></svg>
              <span class="hidden sm:inline">Tabla</span>
            </button>
            <button id="view-card-btn" onclick="setViewMode('card')" class="px-2 py-1.5 text-xs font-medium text-[#F1F3F8] bg-[#6C3CE1]/30 transition-colors flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
              <span class="hidden sm:inline">Cards</span>
            </button>
          </div>
          <!-- Counter -->
          <span class="text-xs text-[#8E94A8] whitespace-nowrap"><span id="filter-count">0</span> vehículo(s)</span>
        </div>

        <!-- Collapsible Filter Panel -->
        <div id="filter-panel" class="hidden border-t border-[#6C3CE1]/10 bg-[#0A0A1A]/20">
          <div class="p-3 space-y-2">
            <!-- Row 1: Dropdowns -->
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
              <div class="flex flex-col gap-0.5">
                <label class="text-[9px] font-medium text-[#8E94A8] uppercase tracking-wider">Marca</label>
                <select id="filter-marca" class="px-2 py-1.5 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                  <option value="" class="bg-[#0A0A1A]">Todas</option>
                </select>
              </div>
              <div class="flex flex-col gap-0.5">
                <label class="text-[9px] font-medium text-[#8E94A8] uppercase tracking-wider">Tipo</label>
                <select id="filter-tipo" class="px-2 py-1.5 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                  <option value="" class="bg-[#0A0A1A]">Todos</option>
                </select>
              </div>
              <div class="flex flex-col gap-0.5">
                <label class="text-[9px] font-medium text-[#8E94A8] uppercase tracking-wider">Sub Tipo</label>
                <select id="filter-subtipo" class="px-2 py-1.5 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                  <option value="" class="bg-[#0A0A1A]">Todos</option>
                </select>
              </div>
              <div class="flex flex-col gap-0.5">
                <label class="text-[9px] font-medium text-[#8E94A8] uppercase tracking-wider">Centro</label>
                <select id="filter-centro" class="px-2 py-1.5 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                  <option value="" class="bg-[#0A0A1A]">Todos</option>
                </select>
              </div>
              <div class="flex flex-col gap-0.5">
                <label class="text-[9px] font-medium text-[#8E94A8] uppercase tracking-wider">Empresa</label>
                <select id="filter-empresa" class="px-2 py-1.5 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                  <option value="" class="bg-[#0A0A1A]">Todas</option>
                </select>
              </div>
              <div class="flex flex-col gap-0.5">
                <label class="text-[9px] font-medium text-[#8E94A8] uppercase tracking-wider">Estado</label>
                <select id="filter-estado" class="px-2 py-1.5 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                  <option value="" class="bg-[#0A0A1A]">Todos</option>
                  <option value="Activo" class="bg-[#0A0A1A]">Activo</option>
                  <option value="Baja" class="bg-[#0A0A1A]">Baja</option>
                </select>
              </div>
            </div>
            <!-- Row 2: Trompo + Limpiar -->
            <div class="flex items-center justify-between pt-1 border-t border-[#6C3CE1]/5">
              <div class="flex items-center gap-2">
                <span class="text-[9px] font-medium text-[#8E94A8] uppercase tracking-wider">Trompo</span>
                <div class="flex rounded-md overflow-hidden border border-[#6C3CE1]/15 bg-[#0A0A1A]/40">
                  <button data-trompo-filter="all" class="px-3 py-1 text-xs font-medium text-[#F1F3F8] bg-[#6C3CE1]/30 transition-colors">Todos</button>
                  <button data-trompo-filter="yes" class="px-3 py-1 text-xs font-medium text-[#8E94A8] hover:text-[#F1F3F8] hover:bg-[#6C3CE1]/10 transition-colors">Si</button>
                  <button data-trompo-filter="no" class="px-3 py-1 text-xs font-medium text-[#8E94A8] hover:text-[#F1F3F8] hover:bg-[#6C3CE1]/10 transition-colors">No</button>
                </div>
              </div>
              <button onclick="resetFilters()" class="px-2.5 py-1 text-xs text-[#8E94A8] hover:text-[#F1F3F8] hover:bg-[#6C3CE1]/10 transition-colors rounded-lg flex items-center gap-1 border border-transparent hover:border-[#6C3CE1]/20">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                Limpiar filtros
              </button>
            </div>
          </div>
        </div>
        <% if (currentUserData?.role === 'Admin') { %>
        <div id="bulk-bar" class="hidden flex items-center justify-between px-4 py-2 bg-[#6C3CE1]/10 border-b border-[#6C3CE1]/20 text-sm">
          <span class="text-[#8E94A8]"><span id="bulk-count">0</span> seleccionado(s)</span>
          <button onclick="deleteSelectedVehicles()" class="px-3 py-1.5 bg-red-600/20 text-red-400 rounded-lg hover:bg-red-600/30 transition text-sm font-medium">🗑️ Eliminar seleccionados</button>
        </div>
        <% } %>
        <div class="table-container p-4 hidden" id="view-table">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-[#8E94A8] border-b border-[#6C3CE1]/10">
                <% if (currentUserData?.role === 'Admin') { %>
                <th class="pb-3 font-medium w-10">
                  <input type="checkbox" id="select-all" onchange="toggleSelectAll(this.checked)" class="accent-[#6C3CE1]">
                </th>
                <% } %>
                <th class="pb-3 font-medium cursor-pointer select-none hover:text-[#F1F3F8] transition-colors" onclick="sortBy('interno')">Interno <span class="sort-arrow text-[#6C3CE1]" data-field="interno">▲</span></th>
                <th class="pb-3 font-medium cursor-pointer select-none hover:text-[#F1F3F8] transition-colors" onclick="sortBy('patente')">Patente <span class="sort-arrow" data-field="patente"></span></th>
                <th class="pb-3 font-medium cursor-pointer select-none hover:text-[#F1F3F8] transition-colors" onclick="sortBy('marca')">Marca / Modelo <span class="sort-arrow" data-field="marca"></span></th>
                <th class="pb-3 font-medium cursor-pointer select-none hover:text-[#F1F3F8] transition-colors" onclick="sortBy('tipo')">Tipo <span class="sort-arrow" data-field="tipo"></span></th>
                <th class="pb-3 font-medium cursor-pointer select-none hover:text-[#F1F3F8] transition-colors" onclick="sortBy('subtipo')">Sub Tipo <span class="sort-arrow" data-field="subtipo"></span></th>
                <th class="pb-3 font-medium">Trompo</th>
                <th class="pb-3 font-medium cursor-pointer select-none hover:text-[#F1F3F8] transition-colors" onclick="sortBy('centroTrabajo')">Centro <span class="sort-arrow" data-field="centroTrabajo"></span></th>
                <th class="pb-3 font-medium no-print">Acciones</th>
              </tr>
            </thead>
            <tbody id="vehiculos-table-body">
              <tr><td colspan="<%= currentUserData?.role === 'Admin' ? 9 : 8 %>" class="text-center py-8 text-[#5C6378]">Cargando vehículos...</td></tr>
            </tbody>
          </table>
        </div>
        <div id="view-card" class="p-4">
          <div id="vehiculos-card-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-4">
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'vehicles' }) %>

<!-- Modal Formulario Vehículo -->
<div id="modal-vehiculo" class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4">
  <div class="glass-card rounded-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto modal-content">
    <div class="flex items-center justify-between p-4 sm:p-6 border-b border-[#6C3CE1]/10 sticky top-0 z-10" style="background: #141e2d;">
      <h3 class="text-base sm:text-lg font-bold text-[#F1F3F8]" id="modal-vehiculo-title">Nuevo Vehículo</h3>
      <button onclick="closeVehicleModal()" class="text-[#8E94A8] hover:text-[#F1F3F8] transition-colors p-1">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form id="form-vehiculo" class="p-4 sm:p-6 space-y-4 sm:space-y-6">
      <input type="hidden" id="vehiculo-id">

      <!-- Sección: Datos Generales -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#6C3CE1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Datos Generales
        </h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">N° Interno</label>
            <input type="text" id="v-interno" readonly class="w-full px-3 py-2 bg-[#0A0A1A]/30 border border-[#6C3CE1]/10 rounded-lg text-sm text-[#5C6378] cursor-not-allowed" placeholder="Se genera automáticamente">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Nro BET</label>
            <input type="text" id="v-nroBet" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Nro asignado por planta">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Patente *</label>
            <input type="text" id="v-patente" required class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="ABC123" maxlength="10" style="text-transform:uppercase">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Marca</label>
            <select id="v-marca" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0A0A1A]">Seleccionar...</option>
              <option value="Mercedes Benz" class="bg-[#0A0A1A]">Mercedes Benz</option>
              <option value="Scania" class="bg-[#0A0A1A]">Scania</option>
              <option value="Volvo" class="bg-[#0A0A1A]">Volvo</option>
              <option value="Iveco" class="bg-[#0A0A1A]">Iveco</option>
              <option value="Volkswagen" class="bg-[#0A0A1A]">Volkswagen</option>
              <option value="Ford" class="bg-[#0A0A1A]">Ford</option>
              <option value="Chevrolet" class="bg-[#0A0A1A]">Chevrolet</option>
              <option value="Toyota" class="bg-[#0A0A1A]">Toyota</option>
              <option value="Fiat" class="bg-[#0A0A1A]">Fiat</option>
              <option value="Renault" class="bg-[#0A0A1A]">Renault</option>
              <option value="Nissan" class="bg-[#0A0A1A]">Nissan</option>
              <option value="JCB" class="bg-[#0A0A1A]">JCB</option>
              <option value="Caterpillar" class="bg-[#0A0A1A]">Caterpillar</option>
              <option value="Komatsu" class="bg-[#0A0A1A]">Komatsu</option>
              <option value="Hyundai" class="bg-[#0A0A1A]">Hyundai</option>
              <option value="New Holland" class="bg-[#0A0A1A]">New Holland</option>
              <option value="John Deere" class="bg-[#0A0A1A]">John Deere</option>
              <option value="Case" class="bg-[#0A0A1A]">Case</option>
              <option value="Terex" class="bg-[#0A0A1A]">Terex</option>
               <option value="Agrale" class="bg-[#0A0A1A]">Agrale</option>
               <option value="Randon" class="bg-[#0A0A1A]">Randon</option>
             </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Modelo</label>
            <input type="text" id="v-modelo" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Modelo">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Año</label>
            <input type="number" id="v-anio" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="2024" min="1980" max="2026">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Chasis (N° de serie)</label>
            <input type="text" id="v-chasis" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="9BM1234567890ABC">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">N° de Motor</label>
            <input type="text" id="v-numeroMotor" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Motor XYZ-12345">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Tipo</label>
            <select id="v-tipo" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0A0A1A]">Seleccionar...</option>
              <option value="Camión volcador" class="bg-[#0A0A1A]">Camión volcador</option>
              <option value="mixer" class="bg-[#0A0A1A]">Mixer</option>
