<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'vehicles' }) %>
  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#6C3CE1]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#6C3CE1] to-[#00D4FF] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>
    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <h1 class="text-2xl font-bold text-gradient-primary">Vehículos</h1>
          <p class="text-[#8E94A8] text-sm">Gestión de flota vehicular</p>
        </div>
        <div class="flex gap-2 flex-wrap">
          <a href="/vehicle/scan" class="btn-secondary text-sm flex items-center gap-1 px-4 py-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h.01M12 12h-.01M12 12h.01M12 12h-.01M12 12h.01M12 12h-.01M8 4h.01M16 4h.01M4 8h.01M4 16h.01M20 8h.01M20 16h.01"/></svg> Escáner
          </a>
          <button onclick="exportVehiclesExcel()" class="btn-secondary text-sm flex items-center gap-1 px-4 py-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg> Exportar Excel
          </button>
          <% if (currentUserData?.role === 'Admin') { %>
          <div class="relative" id="import-dropdown">
            <button onclick="toggleImportMenu()" class="btn-primary text-sm flex items-center gap-1 px-4 py-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg> Importar
            </button>
            <div id="import-menu" class="hidden absolute right-0 mt-2 w-48 glass-card rounded-lg shadow-xl border border-[#6C3CE1]/10 z-10">
              <button onclick="openCsvImport()" class="w-full text-left px-4 py-3 text-sm text-[#F1F3F8] hover:bg-[#6C3CE1]/10 flex items-center gap-2 rounded-lg">
                <svg class="w-4 h-4 text-[#8E94A8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg> Desde CSV
              </button>
            </div>
          </div>
          <button onclick="openVehicleModal()" class="btn-primary text-sm flex items-center gap-1 px-4 py-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Nuevo
          </button>
          <% } %>
        </div>
      </div>

      <!-- Contador total -->
      <div class="mt-6 glass-card rounded-xl p-6 flex items-center gap-4 border border-[#6C3CE1]/10">
        <div class="w-12 h-12 rounded-full bg-[#6C3CE1]/15 flex items-center justify-center">
          <svg class="w-6 h-6 text-[#6C3CE1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2-1h2m10 1l2-1V8a1 1 0 00-1-1h-4"/></svg>
        </div>
        <div>
          <p class="text-sm font-medium text-[#8E94A8] uppercase tracking-wider">Total de Vehículos</p>
          <p class="text-4xl font-bold text-gradient-primary" id="total-vehicles">0</p>
        </div>
      </div>

      <div class="mt-6 glass-card rounded-xl overflow-hidden">
        <!-- Search bar -->
        <div class="p-4 border-b border-[#6C3CE1]/10">
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-[#5C6378]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" id="search-vehiculo" placeholder="Buscá por patente, marca, modelo, interno..." class="w-full pl-10 pr-4 py-3 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-xl text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon transition-all focus:border-[#6C3CE1]/60 focus:ring-1 focus:ring-[#6C3CE1]/30">
          </div>
        </div>
        <!-- Filters -->
        <div class="px-4 py-3 space-y-3 bg-[#0A0A1A]/30">
          <div class="flex flex-wrap items-end gap-3">
            <!-- Marca -->
            <div class="flex flex-col gap-1 min-w-[140px]">
              <label class="text-[10px] font-medium text-[#8E94A8] uppercase tracking-wider">Marca</label>
              <select id="filter-marca" class="px-3 py-2 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                <option value="" class="bg-[#0A0A1A]">Todas</option>
                <option value="Mercedes Benz" class="bg-[#0A0A1A]">Mercedes Benz</option>
                <option value="Scania" class="bg-[#0A0A1A]">Scania</option>
                <option value="Volvo" class="bg-[#0A0A1A]">Volvo</option>
                <option value="Iveco" class="bg-[#0A0A1A]">Iveco</option>
                <option value="Volkswagen" class="bg-[#0A0A1A]">Volkswagen</option>
                <option value="Ford" class="bg-[#0A0A1A]">Ford</option>
                <option value="Chevrolet" class="bg-[#0A0A1A]">Chevrolet</option>
                <option value="Toyota" class="bg-[#0A0A1A]">Toyota</option>
                <option value="Fiat" class="bg-[#0A0A1A]">Fiat</option>
                <option value="Renault" class="bg-[#0A0A1A]">Renault</option>
                <option value="Nissan" class="bg-[#0A0A1A]">Nissan</option>
                <option value="JCB" class="bg-[#0A0A1A]">JCB</option>
                <option value="Caterpillar" class="bg-[#0A0A1A]">Caterpillar</option>
                <option value="Komatsu" class="bg-[#0A0A1A]">Komatsu</option>
                <option value="Hyundai" class="bg-[#0A0A1A]">Hyundai</option>
                <option value="New Holland" class="bg-[#0A0A1A]">New Holland</option>
                <option value="John Deere" class="bg-[#0A0A1A]">John Deere</option>
                <option value="Case" class="bg-[#0A0A1A]">Case</option>
                <option value="Terex" class="bg-[#0A0A1A]">Terex</option>
                <option value="Agrale" class="bg-[#0A0A1A]">Agrale</option>
                <option value="Randon" class="bg-[#0A0A1A]">Randon</option>
              </select>
            </div>
            <!-- Tipo -->
            <div class="flex flex-col gap-1 min-w-[140px]">
              <label class="text-[10px] font-medium text-[#8E94A8] uppercase tracking-wider">Tipo</label>
              <select id="filter-tipo" class="px-3 py-2 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                <option value="" class="bg-[#0A0A1A]">Todos</option>
                <option value="Camión volcador" class="bg-[#0A0A1A]">Camión volcador</option>
                <option value="mixer" class="bg-[#0A0A1A]">Mixer</option>
                <option value="hormigonera" class="bg-[#0A0A1A]">Hormigonera</option>
                <option value="cisterna" class="bg-[#0A0A1A]">Cisterna</option>
                <option value="jaula" class="bg-[#0A0A1A]">Jaula</option>
                <option value="playo" class="bg-[#0A0A1A]">Playo</option>
                <option value="regador" class="bg-[#0A0A1A]">Regador</option>
                <option value="chasis" class="bg-[#0A0A1A]">Chasis</option>
                <option value="Auto" class="bg-[#0A0A1A]">Auto</option>
                <option value="Camioneta" class="bg-[#0A0A1A]">Camioneta</option>
                <option value="Grua" class="bg-[#0A0A1A]">Grua</option>
                <option value="Utilitario" class="bg-[#0A0A1A]">Utilitario</option>
                <option value="Carga" class="bg-[#0A0A1A]">Carga</option>
                <option value="Cargadora frontal" class="bg-[#0A0A1A]">Cargadora frontal</option>
                <option value="Retroexcavadora" class="bg-[#0A0A1A]">Retroexcavadora</option>
                <option value="Motoniveladora" class="bg-[#0A0A1A]">Motoniveladora</option>
                <option value="Excavadora" class="bg-[#0A0A1A]">Excavadora</option>
                <option value="Minicargadora" class="bg-[#0A0A1A]">Minicargadora</option>
                <option value="Rodillo" class="bg-[#0A0A1A]">Rodillo</option>
                <option value="Acoplado" class="bg-[#0A0A1A]">Acoplado</option>
                <option value="Semirremolque" class="bg-[#0A0A1A]">Semirremolque</option>
                <option value="Montacarga" class="bg-[#0A0A1A]">Montacarga</option>
                <option value="Tolva" class="bg-[#0A0A1A]">Tolva</option>
                <option value="Achelo" class="bg-[#0A0A1A]">Achelo</option>
                <option value="Camion" class="bg-[#0A0A1A]">Camion</option>
              </select>
            </div>
            <!-- Sub Tipo -->
            <div class="flex flex-col gap-1 min-w-[140px]">
              <label class="text-[10px] font-medium text-[#8E94A8] uppercase tracking-wider">Sub Tipo</label>
              <select id="filter-subtipo" class="px-3 py-2 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                <option value="" class="bg-[#0A0A1A]">Todos</option>
              </select>
            </div>
            <!-- Centro -->
            <div class="flex flex-col gap-1 min-w-[140px]">
              <label class="text-[10px] font-medium text-[#8E94A8] uppercase tracking-wider">Centro</label>
              <select id="filter-centro" class="px-3 py-2 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                <option value="" class="bg-[#0A0A1A]">Todos</option>
                <option value="Lujan" class="bg-[#0A0A1A]">Lujan</option>
                <option value="Campana" class="bg-[#0A0A1A]">Campana</option>
                <option value="Ituzaingo" class="bg-[#0A0A1A]">Ituzaingo</option>
                <option value="Moreno" class="bg-[#0A0A1A]">Moreno</option>
                <option value="Zarate" class="bg-[#0A0A1A]">Zarate</option>
              </select>
            </div>
            <!-- Empresa -->
            <div class="flex flex-col gap-1 min-w-[140px]">
              <label class="text-[10px] font-medium text-[#8E94A8] uppercase tracking-wider">Empresa</label>
              <select id="filter-empresa" class="px-3 py-2 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                <option value="" class="bg-[#0A0A1A]">Todas</option>
              </select>
            </div>
            <!-- Estado -->
            <div class="flex flex-col gap-1 min-w-[120px]">
              <label class="text-[10px] font-medium text-[#8E94A8] uppercase tracking-wider">Estado</label>
              <select id="filter-estado" class="px-3 py-2 bg-[#0A0A1A]/60 border border-[#6C3CE1]/15 rounded-lg text-xs text-[#F1F3F8] input-neon cursor-pointer">
                <option value="" class="bg-[#0A0A1A]">Todos</option>
                <option value="Activo" class="bg-[#0A0A1A]">Activo</option>
                <option value="Baja" class="bg-[#0A0A1A]">Baja</option>
              </select>
            </div>
            <!-- Limpiar -->
            <button onclick="resetFilters()" class="px-3 py-2 text-xs text-[#8E94A8] hover:text-[#F1F3F8] hover:bg-[#6C3CE1]/10 transition-colors rounded-lg flex items-center gap-1.5 border border-transparent hover:border-[#6C3CE1]/20">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Limpiar
            </button>
          </div>
          <!-- Trompo filter row -->
          <div class="flex flex-wrap items-center gap-3 pt-2 border-t border-[#6C3CE1]/5">
            <span class="text-[10px] font-medium text-[#8E94A8] uppercase tracking-wider">Trompo</span>
            <div class="flex rounded-lg overflow-hidden border border-[#6C3CE1]/15 bg-[#0A0A1A]/40">
              <button data-trompo-filter="all" class="px-4 py-1.5 text-xs font-medium text-[#F1F3F8] bg-[#6C3CE1]/30 transition-colors">Todos</button>
              <button data-trompo-filter="yes" class="px-4 py-1.5 text-xs font-medium text-[#8E94A8] hover:text-[#F1F3F8] hover:bg-[#6C3CE1]/10 transition-colors">Con Trompo</button>
              <button data-trompo-filter="no" class="px-4 py-1.5 text-xs font-medium text-[#8E94A8] hover:text-[#F1F3F8] hover:bg-[#6C3CE1]/10 transition-colors">Sin Trompo</button>
            </div>
          </div>
        </div>
        <div class="px-4 py-1.5 bg-[#6C3CE1]/5 border-b border-[#6C3CE1]/10 flex items-center justify-between">
          <span class="text-xs text-[#8E94A8]"><span id="filter-count">0</span> vehículo(s)</span>
          <button onclick="resetFilters()" class="text-xs text-[#6C3CE1]/70 hover:text-[#6C3CE1] transition-colors">Limpiar filtros</button>
        </div>
        <% if (currentUserData?.role === 'Admin') { %>
        <div id="bulk-bar" class="hidden flex items-center justify-between px-4 py-2 bg-[#6C3CE1]/10 border-b border-[#6C3CE1]/20 text-sm">
          <span class="text-[#8E94A8]"><span id="bulk-count">0</span> seleccionado(s)</span>
          <button onclick="deleteSelectedVehicles()" class="px-3 py-1.5 bg-red-600/20 text-red-400 rounded-lg hover:bg-red-600/30 transition text-sm font-medium">🗑️ Eliminar seleccionados</button>
        </div>
        <% } %>
        <div class="table-container p-4">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-[#8E94A8] border-b border-[#6C3CE1]/10">
                <% if (currentUserData?.role === 'Admin') { %>
                <th class="pb-3 font-medium w-10">
                  <input type="checkbox" id="select-all" onchange="toggleSelectAll(this.checked)" class="accent-[#6C3CE1]">
                </th>
                <% } %>
                <th class="pb-3 font-medium">Interno</th>
                <th class="pb-3 font-medium">Patente</th>
                <th class="pb-3 font-medium">Marca / Modelo</th>
                <th class="pb-3 font-medium">Tipo</th>
                <th class="pb-3 font-medium">Sub Tipo</th>
                <th class="pb-3 font-medium">Trompo</th>
                <th class="pb-3 font-medium">Centro</th>
                <th class="pb-3 font-medium no-print">Acciones</th>
              </tr>
            </thead>
            <tbody id="vehiculos-table-body">
              <tr><td colspan="<%= currentUserData?.role === 'Admin' ? 9 : 8 %>" class="text-center py-8 text-[#5C6378]">Cargando vehículos...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'vehicles' }) %>

<!-- Modal Formulario Vehículo -->
<div id="modal-vehiculo" class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4">
  <div class="glass-card rounded-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto modal-content">
    <div class="flex items-center justify-between p-6 border-b border-[#6C3CE1]/10 sticky top-0 z-10" style="background: #141e2d;">
      <h3 class="text-lg font-bold text-[#F1F3F8]" id="modal-vehiculo-title">Nuevo Vehículo</h3>
      <button onclick="closeVehicleModal()" class="text-[#8E94A8] hover:text-[#F1F3F8] transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form id="form-vehiculo" class="p-6 space-y-6">
      <input type="hidden" id="vehiculo-id">

      <!-- Sección: Datos Generales -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#6C3CE1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Datos Generales
        </h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">N° Interno</label>
            <input type="text" id="v-interno" readonly class="w-full px-3 py-2 bg-[#0A0A1A]/30 border border-[#6C3CE1]/10 rounded-lg text-sm text-[#5C6378] cursor-not-allowed" placeholder="Se genera automáticamente">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Patente *</label>
            <input type="text" id="v-patente" required class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="ABC123" maxlength="10" style="text-transform:uppercase">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Marca *</label>
            <select id="v-marca" required class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0A0A1A]">Seleccionar...</option>
              <option value="Mercedes Benz" class="bg-[#0A0A1A]">Mercedes Benz</option>
              <option value="Scania" class="bg-[#0A0A1A]">Scania</option>
              <option value="Volvo" class="bg-[#0A0A1A]">Volvo</option>
              <option value="Iveco" class="bg-[#0A0A1A]">Iveco</option>
              <option value="Volkswagen" class="bg-[#0A0A1A]">Volkswagen</option>
              <option value="Ford" class="bg-[#0A0A1A]">Ford</option>
              <option value="Chevrolet" class="bg-[#0A0A1A]">Chevrolet</option>
              <option value="Toyota" class="bg-[#0A0A1A]">Toyota</option>
              <option value="Fiat" class="bg-[#0A0A1A]">Fiat</option>
              <option value="Renault" class="bg-[#0A0A1A]">Renault</option>
              <option value="Nissan" class="bg-[#0A0A1A]">Nissan</option>
              <option value="JCB" class="bg-[#0A0A1A]">JCB</option>
              <option value="Caterpillar" class="bg-[#0A0A1A]">Caterpillar</option>
              <option value="Komatsu" class="bg-[#0A0A1A]">Komatsu</option>
              <option value="Hyundai" class="bg-[#0A0A1A]">Hyundai</option>
              <option value="New Holland" class="bg-[#0A0A1A]">New Holland</option>
              <option value="John Deere" class="bg-[#0A0A1A]">John Deere</option>
              <option value="Case" class="bg-[#0A0A1A]">Case</option>
              <option value="Terex" class="bg-[#0A0A1A]">Terex</option>
               <option value="Agrale" class="bg-[#0A0A1A]">Agrale</option>
               <option value="Randon" class="bg-[#0A0A1A]">Randon</option>
             </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Modelo *</label>
            <input type="text" id="v-modelo" required class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Modelo">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Año *</label>
            <input type="number" id="v-anio" required class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="2024" min="1980" max="2026">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Chasis (N° de serie) *</label>
            <input type="text" id="v-chasis" required class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="9BM1234567890ABC">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">N° de Motor *</label>
