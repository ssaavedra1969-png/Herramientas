<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'vehicles' }) %>
  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#FF6B35]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#FF6B35] to-[#FF3366] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>
    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <h1 class="text-2xl font-bold text-gradient-primary">Vehículos</h1>
          <p class="text-[#8E94A8] text-sm">Gestión de flota vehicular</p>
        </div>
        <% if (currentUserData?.role === 'Admin') { %>
        <div class="flex gap-2">
          <div class="relative" id="import-dropdown">
            <button onclick="toggleImportMenu()" class="btn-primary text-sm flex items-center gap-1 px-4 py-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg> Importar
            </button>
            <div id="import-menu" class="hidden absolute right-0 mt-2 w-48 glass-card rounded-lg shadow-xl border border-[#FF6B35]/10 z-10">
              <button onclick="openCsvImport()" class="w-full text-left px-4 py-3 text-sm text-[#F1F3F8] hover:bg-[#FF6B35]/10 flex items-center gap-2 rounded-lg">
                <svg class="w-4 h-4 text-[#8E94A8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg> Desde CSV
              </button>
            </div>
          </div>
          <button onclick="openVehicleModal()" class="btn-primary text-sm flex items-center gap-1 px-4 py-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Nuevo
          </button>
        </div>
        <% } %>
      </div>

      <div class="mt-6 glass-card rounded-xl">
        <div class="p-4 border-b border-[#FF6B35]/10 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between">
          <div class="flex gap-2 flex-wrap">
            <input type="text" id="search-vehiculo" placeholder="Buscar por patente, marca..." class="px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm w-64 text-[#F1F3F8] placeholder-[#5C6378] input-neon">
            <select id="filter-estado" class="px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0B0E17]">Todos los estados</option>
              <option value="Excelente" class="bg-[#0B0E17]">Excelente</option>
              <option value="Bueno" class="bg-[#0B0E17]">Bueno</option>
              <option value="Regular" class="bg-[#0B0E17]">Regular</option>
              <option value="Taller" class="bg-[#0B0E17]">Taller</option>
              <option value="Baja" class="bg-[#0B0E17]">Baja</option>
            </select>
            <button onclick="applyFilters()" class="btn-secondary text-sm px-4 py-2">Filtrar</button>
          </div>
        </div>
        <div id="bulk-bar" class="hidden flex items-center justify-between px-4 py-2 bg-[#FF6B35]/10 border-b border-[#FF6B35]/20 text-sm">
          <span class="text-[#8E94A8]"><span id="bulk-count">0</span> seleccionado(s)</span>
          <button onclick="deleteSelectedVehicles()" class="px-3 py-1.5 bg-red-600/20 text-red-400 rounded-lg hover:bg-red-600/30 transition text-sm font-medium">🗑️ Eliminar seleccionados</button>
        </div>
        <div class="table-container p-4">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-[#8E94A8] border-b border-[#FF6B35]/10">
                <th class="pb-3 font-medium w-10">
                  <input type="checkbox" id="select-all" onchange="toggleSelectAll(this.checked)" class="accent-[#FF6B35]">
                </th>
                <th class="pb-3 font-medium">Interno</th>
                <th class="pb-3 font-medium">Patente</th>
                <th class="pb-3 font-medium">Marca / Modelo</th>
                <th class="pb-3 font-medium">Tipo</th>
                <th class="pb-3 font-medium">Centro</th>
                <th class="pb-3 font-medium no-print">Acciones</th>
              </tr>
            </thead>
            <tbody id="vehiculos-table-body">
              <tr><td colspan="7" class="text-center py-8 text-[#5C6378]">Cargando vehículos...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'vehicles' }) %>

<!-- Modal Formulario Vehículo -->
<div id="modal-vehiculo" class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4">
  <div class="glass-card rounded-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto modal-content">
    <div class="flex items-center justify-between p-6 border-b border-[#FF6B35]/10 sticky top-0 z-10" style="background: #141e2d;">
      <h3 class="text-lg font-bold text-[#F1F3F8]" id="modal-vehiculo-title">Nuevo Vehículo</h3>
      <button onclick="closeVehicleModal()" class="text-[#8E94A8] hover:text-[#F1F3F8] transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form id="form-vehiculo" class="p-6 space-y-6">
      <input type="hidden" id="vehiculo-id">

      <!-- Sección: Datos Generales -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#FF6B35]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Datos Generales
        </h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">N° Interno</label>
            <input type="text" id="v-interno" readonly class="w-full px-3 py-2 bg-[#0B0E17]/30 border border-[#FF6B35]/10 rounded-lg text-sm text-[#5C6378] cursor-not-allowed" placeholder="Se genera automáticamente">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Patente *</label>
            <input type="text" id="v-patente" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="ABC123" maxlength="10" style="text-transform:uppercase">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Marca *</label>
            <select id="v-marca" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0B0E17]">Seleccionar...</option>
              <option value="Mercedes Benz" class="bg-[#0B0E17]">Mercedes Benz</option>
              <option value="Scania" class="bg-[#0B0E17]">Scania</option>
              <option value="Volvo" class="bg-[#0B0E17]">Volvo</option>
              <option value="Iveco" class="bg-[#0B0E17]">Iveco</option>
              <option value="Volkswagen" class="bg-[#0B0E17]">Volkswagen</option>
              <option value="Ford" class="bg-[#0B0E17]">Ford</option>
              <option value="Chevrolet" class="bg-[#0B0E17]">Chevrolet</option>
              <option value="Toyota" class="bg-[#0B0E17]">Toyota</option>
              <option value="Fiat" class="bg-[#0B0E17]">Fiat</option>
              <option value="Renault" class="bg-[#0B0E17]">Renault</option>
              <option value="Nissan" class="bg-[#0B0E17]">Nissan</option>
              <option value="JCB" class="bg-[#0B0E17]">JCB</option>
              <option value="Caterpillar" class="bg-[#0B0E17]">Caterpillar</option>
              <option value="Komatsu" class="bg-[#0B0E17]">Komatsu</option>
              <option value="Hyundai" class="bg-[#0B0E17]">Hyundai</option>
              <option value="New Holland" class="bg-[#0B0E17]">New Holland</option>
              <option value="John Deere" class="bg-[#0B0E17]">John Deere</option>
              <option value="Case" class="bg-[#0B0E17]">Case</option>
              <option value="Terex" class="bg-[#0B0E17]">Terex</option>
              <option value="Agrale" class="bg-[#0B0E17]">Agrale</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Modelo *</label>
            <input type="text" id="v-modelo" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Modelo">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Año *</label>
            <input type="number" id="v-anio" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="2024" min="1980" max="2026">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Chasis (N° de serie) *</label>
            <input type="text" id="v-chasis" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="9BM1234567890ABC">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">N° de Motor *</label>
            <input type="text" id="v-numeroMotor" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Motor XYZ-12345">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Tipo *</label>
            <select id="v-tipo" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0B0E17]">Seleccionar...</option>
              <option value="Camión volcador" class="bg-[#0B0E17]">Camión volcador</option>
              <option value="mixer" class="bg-[#0B0E17]">Mixer</option>
              <option value="hormigonera" class="bg-[#0B0E17]">Hormigonera</option>
              <option value="cisterna" class="bg-[#0B0E17]">Cisterna</option>
              <option value="jaula" class="bg-[#0B0E17]">Jaula</option>
              <option value="playo" class="bg-[#0B0E17]">Playo</option>
              <option value="regador" class="bg-[#0B0E17]">Regador</option>
              <option value="chasis" class="bg-[#0B0E17]">Chasis</option>
              <option value="Auto" class="bg-[#0B0E17]">Auto</option>
              <option value="Camioneta" class="bg-[#0B0E17]">Camioneta</option>
              <option value="Grua" class="bg-[#0B0E17]">Grua</option>
              <option value="Utilitario" class="bg-[#0B0E17]">Utilitario</option>
              <option value="Carga" class="bg-[#0B0E17]">Carga</option>
              <option value="Cargadora frontal" class="bg-[#0B0E17]">Cargadora frontal</option>
              <option value="Retroexcavadora" class="bg-[#0B0E17]">Retroexcavadora</option>
              <option value="Motoniveladora" class="bg-[#0B0E17]">Motoniveladora</option>
              <option value="Excavadora" class="bg-[#0B0E17]">Excavadora</option>
              <option value="Minicargadora" class="bg-[#0B0E17]">Minicargadora</option>
              <option value="Rodillo" class="bg-[#0B0E17]">Rodillo</option>
              <option value="Acoplado" class="bg-[#0B0E17]">Acoplado</option>
              <option value="Semirremolque" class="bg-[#0B0E17]">Semirremolque</option>
              <option value="Montacarga" class="bg-[#0B0E17]">Montacarga</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Sub Tipo *</label>
            <select id="v-subtipo" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0B0E17]">Seleccionar...</option>
              <option value="Indumix" class="bg-[#0B0E17]">Indumix</option>
              <option value="Tzr" class="bg-[#0B0E17]">Tzr</option>
              <option value="Betonmac" class="bg-[#0B0E17]">Betonmac</option>
              <option value="tecnus" class="bg-[#0B0E17]">Tecnus</option>
              <option value="Barival" class="bg-[#0B0E17]">Barival</option>
              <option value="everdingm" class="bg-[#0B0E17]">Everdingm</option>
              <option value="arrastre" class="bg-[#0B0E17]">Arrastre</option>
              <option value="Montacarga" class="bg-[#0B0E17]">Montacarga</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Capacidad de Carga (kg)</label>
            <input type="number" id="v-capacidadCarga" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="25000" step="100">
          </div>
        </div>
      </div>

      <hr class="border-[#FF6B35]/10">

      <!-- Sección: Estado y Mediciones -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Estado y Mediciones
        </h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Kilometraje</label>
            <input type="number" id="v-kilometraje" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="0">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">VTV - Fecha Realización</label>
            <input type="date" id="v-vtvFechaRealizacion" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">VTV - Vencimiento *</label>
            <input type="date" id="v-vencimientoVTV" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">VTV - Costo ($)</label>
            <input type="number" id="v-vtvCosto" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="0" step="0.01">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">VTV - Centro Medición</label>
            <input type="text" id="v-vtvCentro" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Centro de revisión técnica">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">VTV - Resultado</label>
            <select id="v-vtvResultado" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="Pendiente" class="bg-[#0B0E17]">Pendiente</option>
              <option value="Aprobado" class="bg-[#0B0E17]">Aprobado</option>
              <option value="Rechazado" class="bg-[#0B0E17]">Rechazado</option>
            </select>
          </div>
        </div>
      </div>

      <hr class="border-[#FF6B35]/10">

      <!-- Sección: Seguro -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Seguro
        </h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Compañía / Marca *</label>
            <input type="text" id="v-seguroCompania" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Rivadavia Seguros">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">N° Póliza</label>
            <input type="text" id="v-seguroPoliza" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="POL-2024-12345">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Tipo de Seguro *</label>
            <select id="v-seguroTipo" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0B0E17]">Seleccionar...</option>
              <option value="Responsabilidad Civil" class="bg-[#0B0E17]">Responsabilidad Civil</option>
              <option value="Todo Riesgo" class="bg-[#0B0E17]">Todo Riesgo</option>
              <option value="Terceros Completo" class="bg-[#0B0E17]">Terceros Completo</option>
              <option value="Seguro Técnico" class="bg-[#0B0E17]">Seguro Técnico</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Vencimiento del seguro</label>
            <input type="date" id="v-seguroVencimiento" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Costo del seguro ($)</label>
            <input type="number" id="v-seguroCosto" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="0" step="0.01">
          </div>
        </div>
      </div>

      <hr class="border-[#FF6B35]/10">

      <!-- Sección: Service -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Service
        </h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Próximo service (km)</label>
            <input type="number" id="v-proximoServiceKm" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="10000">
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Próximo service (fecha)</label>
            <input type="date" id="v-proximoServiceFecha" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
          </div>
        </div>
      </div>

      <hr class="border-[#FF6B35]/10">

      <!-- Sección: Ubicación y Conductor -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Ubicación y Conductor
        </h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Centro de Trabajo *</label>
            <select id="v-centroTrabajo" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0B0E17]">Seleccionar...</option>
              <option value="Lujan" class="bg-[#0B0E17]">Lujan</option>
              <option value="Campana" class="bg-[#0B0E17]">Campana</option>
              <option value="Ituzaingo" class="bg-[#0B0E17]">Ituzaingo</option>
              <option value="Moreno" class="bg-[#0B0E17]">Moreno</option>
              <option value="Zarate" class="bg-[#0B0E17]">Zarate</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#8E94A8] mb-1">Conductor habitual</label>
            <input type="text" id="v-conductorHabitual" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Juan Pérez">
          </div>
        </div>
      </div>

      <!-- Sección: Multas -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          Multas
        </h4>
        <div id="multas-container" class="space-y-2">
          <div class="text-sm text-[#5C6378] italic">Sin multas registradas</div>
        </div>
        <button type="button" onclick="addMultaRow()" class="mt-2 px-3 py-1.5 text-xs bg-red-500/10 text-red-400 rounded-lg hover:bg-red-500/20 transition">+ Agregar multa</button>
      </div>

      <hr class="border-[#FF6B35]/10">

      <!-- Sección: Documentos -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Documentos
        </h4>
        <div id="documentos-container" class="space-y-2">
          <div class="text-sm text-[#5C6378] italic">Sin documentos adjuntos</div>
        </div>
        <button type="button" onclick="addDocumentoRow()" class="mt-2 px-3 py-1.5 text-xs bg-teal-500/10 text-teal-400 rounded-lg hover:bg-teal-500/20 transition">+ Agregar documento</button>
      </div>

      <hr class="border-[#FF6B35]/10">

      <!-- Sección: Observaciones -->
      <div>
        <h4 class="text-md font-semibold text-[#F1F3F8] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#8E94A8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
          Observaciones
        </h4>
        <textarea id="v-observaciones" rows="3" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Notas adicionales..."></textarea>
      </div>

      <!-- Sección: Foto -->
      <div>
        <label class="block text-sm font-medium text-[#8E94A8] mb-1">Foto (URL)</label>
        <input type="url" id="v-foto" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="https://storage.googleapis.com/...">
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-[#FF6B35]/10">
        <button type="button" onclick="closeVehicleModal()" class="px-4 py-2 text-[#8E94A8] hover:text-[#F1F3F8] text-sm transition-colors">Cancelar</button>
        <button type="submit" class="btn-primary text-sm px-6 py-2">Guardar</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Importación CSV -->
<div id="modal-csv-import" class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4">
  <div class="glass-card rounded-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto modal-content">
    <div class="flex items-center justify-between p-6 border-b border-[#FF6B35]/10 sticky top-0 z-10" style="background: #141e2d;">
      <h3 class="text-lg font-bold text-[#F1F3F8]">Importar vehículos</h3>
      <button onclick="closeCsvImport()" class="text-[#8E94A8] hover:text-[#F1F3F8] transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="p-6 space-y-4">
      <div class="flex items-center gap-4 p-4 bg-[#FF6B35]/10 rounded-lg border border-[#FF6B35]/10">
        <span class="text-sm text-[#F1F3F8]">1. Descargá la plantilla →</span>
        <button onclick="downloadCsvTemplate()" class="btn-secondary text-xs px-3 py-1.5">CSV</button>
        <button onclick="downloadExcelTemplate()" class="btn-secondary text-xs px-3 py-1.5">Excel (.xlsx)</button>
      </div>
      <div>
        <label class="block text-sm font-medium text-[#8E94A8] mb-2">2. Seleccioná el archivo (CSV o Excel):</label>
        <input type="file" id="csv-file-input" accept=".csv,.xlsx,.xls" class="block w-full text-sm text-[#F1F3F8] file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-[#FF6B35]/10 file:text-[#FF6B35] hover:file:bg-[#FF6B35]/20">
      </div>
      <div id="csv-import-preview"></div>
      <div class="flex justify-end gap-3">
        <button type="button" onclick="closeCsvImport()" class="px-4 py-2 text-[#8E94A8] hover:text-[#F1F3F8] text-sm transition-colors">Cancelar</button>
        <button type="button" onclick="validateCsvImport()" class="btn-secondary text-sm px-4 py-2">Validar archivo</button>
        <button type="button" id="btn-execute-csv" onclick="executeCsvImport()" class="btn-primary text-sm px-4 py-2 hidden">Importar</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Progreso -->
<div id="modal-progress" class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4">
  <div class="glass-card rounded-2xl w-full max-w-md modal-content p-6">
    <h3 class="text-lg font-bold text-[#F1F3F8] mb-4">Importando vehículos...</h3>
    <div class="progress-bar w-full mb-2">
      <div id="progress-bar" class="progress-bar-fill" style="width:0%"></div>
    </div>
    <p id="progress-text" class="text-sm text-[#8E94A8] text-center">Preparando...</p>
    <p id="progress-detail" class="text-xs text-[#5C6378] text-center mt-1"></p>
    <button id="btn-progress-close" onclick="closeProgressModal()" class="mt-4 w-full px-4 py-2 bg-[#FF6B35]/10 text-[#FF6B35] text-sm rounded-lg hover:bg-[#FF6B35]/20 transition hidden">Cerrar</button>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
