            <label class="block text-xs text-[#5C6378] mb-1">Dirección</label>
            <input type="text" id="exp-direccion" value="San Martín, Buenos Aires" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
          </div>
          <div>
            <label class="block text-xs text-[#5C6378] mb-1">Teléfono</label>
            <input type="text" id="exp-telefono" value="" class="w-full px-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/20 rounded-lg text-sm text-[#F1F3F8] input-neon" placeholder="Opcional">
