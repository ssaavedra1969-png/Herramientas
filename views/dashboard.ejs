<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'dashboard' }) %>

  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#FF6B35]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#FF6B35] to-[#FF3366] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>

    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <h1 class="text-2xl font-bold text-gradient-primary">Dashboard</h1>
          <p class="text-[#8E94A8] text-sm">Panel de control general</p>
        </div>
      </div>

      <!-- TABS -->
      <div class="mt-6 flex gap-1 border-b border-[#FF6B35]/20">
        <button id="tab-btn-vehiculos" onclick="switchTab('vehiculos')" class="px-5 py-2.5 text-sm font-medium rounded-t-lg transition-all tab-btn-active text-[#FF6B35] border-b-2 border-[#FF6B35]">Vehículos</button>
        <button id="tab-btn-herramientas" onclick="switchTab('herramientas')" class="px-5 py-2.5 text-sm font-medium rounded-t-lg transition-all text-[#8E94A8] hover:text-[#F1F3F8]">Herramientas</button>
      </div>

      <!-- TAB: VEHÍCULOS -->
      <div id="tab-vehiculos" class="tab-content">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6" id="summary-cards-vehiculos">
          <div class="glass-card rounded-xl p-5 card-3d">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Vehículos Activos</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-vehiculos">-</p>
              </div>
              <div class="w-12 h-12 bg-[#FF6B35]/10 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-[#FF6B35]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-5 card-3d">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Vencidos Hoy</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-vencidos">-</p>
              </div>
              <div class="w-12 h-12 bg-orange-500/10 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-5 card-3d">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Próximos 7 Días</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-proximos">-</p>
              </div>
              <div class="w-12 h-12 bg-green-500/10 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
          <div class="lg:col-span-2 glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Mantenimientos por Mes</h3>
            <div class="chart-container" style="position:relative;height:250px;"><canvas id="chart-mantenimientos"></canvas></div>
          </div>
          <div class="glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Alertas Activas</h3>
            <div id="alertas-lista" class="space-y-2 max-h-72 overflow-y-auto pr-1">
              <p class="text-[#5C6378] text-sm">Cargando alertas...</p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
          <div class="lg:col-span-2 glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Consumo de Combustible</h3>
            <div class="chart-container" style="position:relative;height:250px;"><canvas id="chart-combustible"></canvas></div>
          </div>
          <div class="glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Distribución de Gastos</h3>
            <div class="chart-container" style="position:relative;height:250px;"><canvas id="chart-gastos-donut"></canvas></div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
          <div class="glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Gasto en Combustible por Vehículo</h3>
            <div class="chart-container" style="position:relative;height:250px;"><canvas id="chart-gasto-vehiculos"></canvas></div>
          </div>
          <div class="glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Últimos Movimientos</h3>
            <div id="ultimos-movimientos" class="space-y-1 max-h-72 overflow-y-auto pr-1">
              <p class="text-[#5C6378] text-sm">Cargando...</p>
            </div>
          </div>
        </div>

        <div class="glass-card rounded-xl p-5 mt-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-[#F1F3F8]">Vehículos Recientes</h3>
            <a href="/vehicles" class="text-xs text-[#FF6B35] hover:underline">Ver todos →</a>
          </div>
          <div id="dashboard-vehicles-list" class="space-y-1 max-h-72 overflow-y-auto pr-1">
            <p class="text-[#5C6378] text-sm">Cargando...</p>
          </div>
        </div>
      </div>

      <!-- TAB: HERRAMIENTAS -->
      <div id="tab-herramientas" class="tab-content hidden">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6" id="summary-cards-herramientas">
          <div class="glass-card rounded-xl p-5 card-3d">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Htas. en Mal Estado</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-herramientas">-</p>
              </div>
              <div class="w-12 h-12 bg-red-500/10 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-5 card-3d">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Total Herramientas</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-total-herramientas">-</p>
              </div>
              <div class="w-12 h-12 bg-[#10B981]/10 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-5 card-3d">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Próximo Control</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-prox-control">-</p>
              </div>
              <div class="w-12 h-12 bg-blue-500/10 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
            </div>
          </div>
        </div>

        <div class="glass-card rounded-xl p-5 mt-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-[#F1F3F8]">Estado de Herramientas</h3>
            <a href="/tools" class="text-xs text-[#10B981] hover:underline">Ver todas →</a>
          </div>
          <div id="tools-status-list" class="space-y-1 max-h-64 overflow-y-auto pr-1">
            <p class="text-[#5C6378] text-sm">Cargando...</p>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'dashboard' }) %>

<script src="/js/dashboard.js?v=44e609d"></script>
<%- include('partials/footer') %>
