<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'dashboard' }) %>

  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#6C3CE1]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#6C3CE1] to-[#00D4FF] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>

    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="text-left">
          <h1 class="text-2xl font-bold text-gradient-primary">Dashboard</h1>
          <p class="text-[#8E94A8] text-sm">Panel de control general</p>
        </div>
        <!-- Digital Clock -->
        <div class="flex flex-col items-center sm:items-end select-none" style="filter: drop-shadow(0 4px 12px rgba(108,60,222,0.35));">
          <div id="dash-clock" class="relative font-black tracking-[0.15em] leading-none"
               style="font-size:3rem;background:linear-gradient(135deg,#6C3CE1 0%,#8B5CF6 40%,#00D4FF 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
                      text-shadow:none;
                      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.6)) drop-shadow(0 0 8px rgba(108,60,222,0.4));
                      -webkit-text-stroke: 0.5px rgba(255,255,255,0.08);">
            00:00:00
          </div>
          <p id="dash-date" class="text-[#A0A8BF] font-medium mt-1" style="font-size:0.7rem;letter-spacing:0.08em;text-shadow:0 1px 3px rgba(0,0,0,0.5);"></p>
        </div>
      </div>

      <!-- Quick Search -->
      <div class="relative mt-4">
        <div class="glass-card rounded-xl overflow-hidden">
          <div class="flex items-center gap-2 p-3">
            <div class="relative flex-1">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#5C6378]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <input type="text" id="dash-search"
                placeholder="Buscar por patente, interno, marca, empresa..."
                class="w-full pl-9 pr-3 py-2 bg-[#0A0A1A]/50 border border-[#6C3CE1]/15 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon transition-all focus:border-[#6C3CE1]/50"
                autocomplete="off">
            </div>
          </div>
        </div>
        <div id="dash-search-results" class="absolute left-0 right-0 mt-1 glass-card rounded-xl overflow-hidden z-50 hidden max-h-80 overflow-y-auto"></div>
      </div>

      <h2 class="text-xl font-bold text-gradient-primary mt-6 mb-1">Alertas</h2>

      <!-- TAB: VEHÍCULOS -->
      <div id="tab-vehiculos" class="tab-content">
        <!-- Alertas Vehículos -->
        <p class="text-sm font-semibold text-[#8E94A8] mt-4 mb-2 uppercase tracking-wider">Vehículos</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center cursor-pointer hover:border-[#6C3CE1]/30 transition" onclick="showVehiculosModal()">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">Vehículos Activos</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-vehiculos"><span class="skeleton skeleton-stat inline-block"></span></p>
              </div>
              <div class="w-10 h-10 bg-[#6C3CE1]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#6C3CE1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center cursor-pointer hover:border-[#F59E0B]/30 transition" onclick="showVtvAlertModal()">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">VTV por vencer</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-vtv-proximas"><span class="skeleton skeleton-stat inline-block"></span></p>
                <p class="text-xs text-[#5C6378] mt-1">≤30 días</p>
              </div>
              <div class="w-10 h-10 bg-[#F59E0B]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center cursor-pointer hover:border-[#8B5CF6]/30 transition" onclick="showSeguroModal()">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">Seguro por vencer</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-seguro-proximos"><span class="skeleton skeleton-stat inline-block"></span></p>
                <p class="text-xs text-[#5C6378] mt-1">≤30 días</p>
              </div>
              <div class="w-10 h-10 bg-[#8B5CF6]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#8B5CF6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Alertas Choferes -->
        <p class="text-sm font-semibold text-[#8E94A8] mt-6 mb-2 uppercase tracking-wider">Choferes</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center cursor-pointer hover:border-[#EC4899]/30 transition" onclick="showRegistroModal()">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">Registro por vencer</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-registro-proximos"><span class="skeleton skeleton-stat inline-block"></span></p>
                <p class="text-xs text-[#5C6378] mt-1">≤30 días</p>
              </div>
              <div class="w-10 h-10 bg-[#EC4899]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#EC4899]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center cursor-pointer hover:border-[#F97316]/30 transition" onclick="showDniModal()">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">DNI por vencer</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-dni-proximos"><span class="skeleton skeleton-stat inline-block"></span></p>
                <p class="text-xs text-[#5C6378] mt-1">≤30 días</p>
              </div>
              <div class="w-10 h-10 bg-[#F97316]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#F97316]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Summary Cards Row 2: Empresas -->
        <div class="glass-card rounded-xl p-5 card-3d mt-4">
          <div class="flex items-center justify-between mb-4">
            <div>
              <p class="text-lg font-semibold text-[#F1F3F8]">Empresas</p>
              <p class="text-[#5C6378] text-xs">Click en una empresa para ver sus vehículos</p>
            </div>
            <div class="w-10 h-10 bg-[#10B981]/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
          </div>
          <div id="empresas-list" class="space-y-2 overflow-y-auto max-h-60 pr-1">
            <div class="space-y-2"><div class="skeleton skeleton-row" style="height:2rem"></div><div class="skeleton skeleton-row" style="height:2rem;width:75%"></div><div class="skeleton skeleton-row" style="height:2rem;width:50%"></div></div>
          </div>
        </div>

        <!-- Fleet Health -->
        <div class="glass-card rounded-xl p-5 mt-4" style="border:1px solid rgba(16,185,129,0.15);">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,#10B981,#059669);">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-[#F1F3F8]">Estado de la Flota</h3>
              <p class="text-[#5C6378] text-xs">Documentación y vencimientos al día</p>
            </div>
          </div>
          <div id="fleet-health-bar" class="mb-3">
            <div class="h-3 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.06);">
              <div id="fleet-health-fill" class="h-full rounded-full transition-all duration-700" style="width:0%;background:linear-gradient(90deg,#10B981,#059669);"></div>
            </div>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3" id="fleet-health-stats">
            <div class="text-center p-2 rounded-lg" style="background:rgba(16,185,129,0.06);">
              <p class="text-[#10B981] text-lg font-bold" id="fh-ok">—</p>
              <p class="text-[#5C6378] text-[10px] uppercase tracking-wider">Al día</p>
            </div>
            <div class="text-center p-2 rounded-lg" style="background:rgba(249,115,22,0.06);">
              <p class="text-[#F97316] text-lg font-bold" id="fh-warn">—</p>
              <p class="text-[#5C6378] text-[10px] uppercase tracking-wider">Por vencer</p>
            </div>
            <div class="text-center p-2 rounded-lg" style="background:rgba(239,68,68,0.06);">
              <p class="text-[#EF4444] text-lg font-bold" id="fh-crit">—</p>
              <p class="text-[#5C6378] text-[10px] uppercase tracking-wider">Vencidos</p>
            </div>
            <div class="text-center p-2 rounded-lg" style="background:rgba(108,60,222,0.06);">
              <p class="text-[#6C3CE1] text-lg font-bold" id="fh-total">—</p>
              <p class="text-[#5C6378] text-[10px] uppercase tracking-wider">Total</p>
            </div>
          </div>
        </div>

        <!-- Dashboard Detail Modal (genérico) -->
        <div id="dash-modal" class="fixed inset-0 z-50 hidden">
          <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeDashModal()"></div>
          <div class="absolute inset-0 flex items-center justify-center p-4">
            <div class="glass-card rounded-2xl w-full max-w-md overflow-hidden" style="border:1px solid rgba(108,60,222,0.25);box-shadow:0 25px 60px -12px rgba(0,0,0,0.9),0 0 40px rgba(108,60,222,0.1);">
              <div id="dash-modal-header" class="px-5 pt-5 pb-3 flex items-center gap-3" style="border-bottom:1px solid rgba(255,255,255,0.06);">
                <div id="dash-modal-icon" class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"></div>
                <div class="flex-1">
                  <h3 id="dash-modal-title" class="text-lg font-bold text-[#F1F3F8]"></h3>
                  <p id="dash-modal-subtitle" class="text-[11px] text-[#8E94A8] mt-0.5"></p>
                </div>
                <button onclick="closeDashModal()" class="w-8 h-8 rounded-lg flex items-center justify-center text-[#5C6378] hover:text-[#F1F3F8] hover:bg-white/5 transition">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>
              <div id="dash-modal-body" class="px-5 py-4 max-h-80 overflow-y-auto space-y-2"></div>
              <div id="dash-modal-footer" class="px-5 py-3 border-t border-white/5 flex justify-end">
                <button onclick="closeDashModal()" class="px-5 py-2 rounded-xl text-sm font-semibold transition" style="background:linear-gradient(135deg,#6C3CE1,#00D4FF);color:#fff;">Cerrar</button>
              </div>
            </div>
          </div>
        </div>

      </div>

    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'dashboard' }) %>

<script src="/js/dashboard.js?v=44e609d"></script>
<script>
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDashModal(); });
</script>
<%- include('partials/footer') %>
