<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'dashboard' }) %>

  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#6C3CE1]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#6C3CE1] to-[#00D4FF] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>

    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <h1 class="text-2xl font-bold text-gradient-primary">Dashboard</h1>
          <p class="text-[#8E94A8] text-sm">Panel de control general</p>
        </div>
      </div>

      <!-- TABS -->
      <div class="mt-6 flex gap-1 border-b border-[#6C3CE1]/20">
        <button id="tab-btn-vehiculos" onclick="switchTab('vehiculos')" class="px-5 py-2.5 text-sm font-medium rounded-t-lg transition-all tab-btn-active text-[#6C3CE1] border-b-2 border-[#6C3CE1]">Vehículos</button>

      </div>

      <!-- TAB: VEHÍCULOS -->
      <div id="tab-vehiculos" class="tab-content">
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
          <div class="glass-card rounded-xl p-5 card-3d flex flex-col justify-center min-h-[180px]">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Vehículos Activos</p>
                <p class="text-4xl font-bold text-[#F1F3F8] mt-1" id="card-vehiculos">-</p>
                <p class="text-xs text-[#5C6378] mt-2">Total de vehículos en operación</p>
              </div>
              <div class="w-14 h-14 bg-[#6C3CE1]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-7 h-7 text-[#6C3CE1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-5 card-3d flex flex-col min-h-[180px]">
            <div class="flex items-center justify-between shrink-0">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Empresas</p>
                <p class="text-4xl font-bold text-[#F1F3F8] mt-1" id="card-empresas">-</p>
              </div>
              <div class="w-14 h-14 bg-[#10B981]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-7 h-7 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              </div>
            </div>
            <div id="empresas-list" class="mt-3 space-y-1 overflow-y-auto flex-1 pr-1">
              <p class="text-[#5C6378] text-sm">Cargando...</p>
            </div>
          </div>
        </div>

        <!-- Alertas VTV -->
        <div class="glass-card rounded-xl p-5 mt-6">
          <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Alertas VTV</h3>
          <div id="alertas-vtv" class="space-y-2 max-h-72 overflow-y-auto pr-1">
            <p class="text-[#5C6378] text-sm">Cargando alertas...</p>
          </div>
        </div>

        <!-- Charts -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
          <div class="glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Consumo de Combustible</h3>
            <div class="chart-container" style="position:relative;height:250px;"><canvas id="chart-combustible"></canvas></div>
          </div>
          <div class="glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Gasto en Combustible por Vehículo</h3>
            <div class="chart-container" style="position:relative;height:250px;"><canvas id="chart-gasto-vehiculos"></canvas></div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'dashboard' }) %>

<script src="/js/dashboard.js?v=44e609d"></script>
<%- include('partials/footer') %>
