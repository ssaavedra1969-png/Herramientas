<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'dashboard' }) %>

  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#6C3CE1]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#6C3CE1] to-[#00D4FF] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>

    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <h1 class="text-2xl font-bold text-gradient-primary">Dashboard</h1>
          <p class="text-[#8E94A8] text-sm">Panel de control general</p>
        </div>
      </div>

      <!-- TABS -->
      <div class="mt-6 flex gap-1 border-b border-[#6C3CE1]/20">
        <button id="tab-btn-vehiculos" onclick="switchTab('vehiculos')" class="px-5 py-2.5 text-sm font-medium rounded-t-lg transition-all tab-btn-active text-[#6C3CE1] border-b-2 border-[#6C3CE1]">Vehículos</button>

      </div>

      <!-- TAB: VEHÍCULOS -->
      <div id="tab-vehiculos" class="tab-content">
        <!-- Summary Cards Row 1 -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">Vehículos Activos</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-vehiculos">-</p>
              </div>
              <div class="w-10 h-10 bg-[#6C3CE1]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#6C3CE1]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">VTV por vencer</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-vtv-proximas">-</p>
                <p class="text-xs text-[#5C6378] mt-1">≤30 días</p>
              </div>
              <div class="w-10 h-10 bg-[#F59E0B]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">Seguro por vencer</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-seguro-proximos">-</p>
                <p class="text-xs text-[#5C6378] mt-1">≤30 días</p>
              </div>
              <div class="w-10 h-10 bg-[#8B5CF6]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#8B5CF6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
            </div>
          </div>
          <div class="glass-card rounded-xl p-4 card-3d flex flex-col justify-center">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#8E94A8] text-xs font-medium">Gasto del mes</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-gasto-mes">-</p>
                <p class="text-xs text-[#5C6378] mt-1">combustible + repuestos</p>
              </div>
              <div class="w-10 h-10 bg-[#10B981]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Summary Cards Row 2: Empresas -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
          <div class="glass-card rounded-xl p-5 card-3d flex flex-col min-h-[160px]">
            <div class="flex items-center justify-between shrink-0">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Empresas</p>
                <p class="text-3xl font-bold text-[#F1F3F8] mt-1" id="card-empresas">-</p>
              </div>
              <div class="w-10 h-10 bg-[#10B981]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              </div>
            </div>
            <div id="empresas-list" class="mt-3 space-y-1 overflow-y-auto flex-1 pr-1">
              <p class="text-[#5C6378] text-sm">Cargando...</p>
            </div>
          </div>
          <div class="glass-card rounded-xl p-5 card-3d flex flex-col min-h-[160px]">
            <div class="flex items-center justify-between shrink-0">
              <div>
                <p class="text-[#8E94A8] text-sm font-medium">Distribución de Gastos</p>
              </div>
              <div class="w-10 h-10 bg-[#F59E0B]/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
              </div>
            </div>
            <div class="chart-container flex-1" style="position:relative;min-height:120px;"><canvas id="chart-donut-gastos"></canvas></div>
          </div>
        </div>

        <!-- Alertas VTV + Seguro -->
        <div class="glass-card rounded-xl p-5 mt-4">
          <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Alertas VTV / Seguro</h3>
          <div id="alertas-vtv" class="space-y-2 max-h-72 overflow-y-auto pr-1">
            <p class="text-[#5C6378] text-sm">Cargando alertas...</p>
          </div>
        </div>

        <!-- Charts -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
          <div class="glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Consumo de Combustible</h3>
            <div class="chart-container" style="position:relative;height:250px;"><canvas id="chart-combustible"></canvas></div>
          </div>
          <div class="glass-card rounded-xl p-5">
            <h3 class="text-lg font-semibold text-[#F1F3F8] mb-4">Gasto en Combustible por Vehículo</h3>
            <div class="chart-container" style="position:relative;height:250px;"><canvas id="chart-gasto-vehiculos"></canvas></div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'dashboard' }) %>

<script src="/js/dashboard.js?v=44e609d"></script>
<%- include('partials/footer') %>
