<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'admin' }) %>
  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#FF6B35]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#FF6B35] to-[#FF3366] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>
    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <h1 class="text-2xl font-bold text-gradient-primary">Usuarios</h1>
          <p class="text-[#8E94A8] text-sm">Gestión de usuarios y roles</p>
        </div>
      </div>

      <div class="mt-6 glass-card rounded-xl">
        <div class="p-4 border-b border-[#FF6B35]/10">
          <p class="text-sm text-[#8E94A8]">Solo los administradores pueden modificar roles.</p>
        </div>
        <div class="table-container p-4">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-[#8E94A8] border-b border-[#FF6B35]/10">
                <th class="pb-3 font-medium">Nombre</th>
                <th class="pb-3 font-medium">Email</th>
                <th class="pb-3 font-medium">Rol</th>
                <th class="pb-3 font-medium">Fecha de registro</th>
                <th class="pb-3 font-medium no-print">Acciones</th>
              </tr>
            </thead>
            <tbody id="users-table-body">
              <tr><td colspan="5" class="text-center py-8 text-[#5C6378]">Cargando usuarios...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'admin' }) %>

<div id="modal-usuario" class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4">
  <div class="glass-card rounded-2xl w-full max-w-md modal-content">
    <div class="flex items-center justify-between p-6 border-b border-[#FF6B35]/10">
      <h3 class="text-lg font-bold text-[#F1F3F8]">Editar Rol de Usuario</h3>
      <button onclick="closeUserModal()" class="text-[#8E94A8] hover:text-[#F1F3F8] transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form id="form-usuario" class="p-6 space-y-4">
      <input type="hidden" id="user-id">
      <div>
        <label class="block text-sm font-medium text-[#8E94A8] mb-1">Nombre</label>
        <p id="user-display-name" class="text-[#F1F3F8] font-medium"></p>
      </div>
      <div>
        <label class="block text-sm font-medium text-[#8E94A8] mb-1">Email</label>
        <p id="user-email" class="text-[#F1F3F8]"></p>
      </div>
      <div>
        <label class="block text-sm font-medium text-[#8E94A8] mb-1">Rol *</label>
        <select id="user-role" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
          <option value="Usuario" class="bg-[#0B0E17]">Usuario</option>
          <option value="Admin" class="bg-[#0B0E17]">Admin</option>
        </select>
      </div>
      <div class="flex justify-end gap-3 pt-4 border-t border-[#FF6B35]/10">
        <button type="button" onclick="closeUserModal()" class="px-4 py-2 text-[#8E94A8] hover:text-[#F1F3F8] text-sm transition-colors">Cancelar</button>
        <button type="submit" class="btn-primary text-sm px-6 py-2">Guardar</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/admin.js"></script>
<%- include('partials/footer') %>
