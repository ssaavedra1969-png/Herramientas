<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'tools' }) %>
  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden bg-blue-900 text-white p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-blue-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-blue-700 rounded-full flex items-center justify-center text-sm font-bold"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>
    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <h1 class="text-2xl font-bold text-gray-800">Herramientas</h1>
          <p class="text-gray-500 text-sm">Inventario de herramientas</p>
        </div>
        <% if (currentUserData?.role === 'Admin') { %>
        <button onclick="openToolModal()" class="px-4 py-2 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700 transition flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Nueva
        </button>
        <% } %>
      </div>

      <div class="mt-6 bg-white rounded-xl shadow-sm">
        <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between">
          <div class="flex gap-2 flex-wrap">
            <input type="text" id="search-herramienta" placeholder="Buscar por nombre o código..." class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-64 focus:ring-2 focus:ring-blue-500">
            <select id="filter-estado-herramienta" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500">
              <option value="">Todos los estados</option>
              <option value="Bueno">Bueno</option>
              <option value="Regular">Regular</option>
              <option value="Roto">Roto</option>
              <option value="En reparación">En reparación</option>
            </select>
          </div>
        </div>
        <div class="table-container p-4">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-500 border-b border-gray-200">
                <th class="pb-3 font-medium">Código</th>
                <th class="pb-3 font-medium">Nombre</th>
                <th class="pb-3 font-medium">Tipo</th>
                <th class="pb-3 font-medium">Estado</th>
                <th class="pb-3 font-medium">Ubicación</th>
                <th class="pb-3 font-medium">Últ. Control</th>
                <th class="pb-3 font-medium">Próx. Control</th>
                <th class="pb-3 font-medium no-print">Acciones</th>
              </tr>
            </thead>
            <tbody id="tools-table-body">
              <tr><td colspan="8" class="text-center py-8 text-gray-400">Cargando herramientas...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'tools' }) %>

<div id="modal-herramienta" class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto modal-content">
    <div class="flex items-center justify-between p-6 border-b border-gray-200">
      <h3 class="text-lg font-bold text-gray-800" id="modal-herramienta-title">Nueva Herramienta</h3>
      <button onclick="closeToolModal()" class="text-gray-400 hover:text-gray-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form id="form-herramienta" class="p-6 space-y-4">
      <input type="hidden" id="herramienta-id">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
          <input type="text" id="h-nombre" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Taladro">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Código Interno *</label>
          <input type="text" id="h-codigo" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="TAL-001">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tipo *</label>
          <select id="h-tipo" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <option value="Eléctrica">Eléctrica</option>
            <option value="Neumática">Neumática</option>
            <option value="Manual">Manual</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Estado *</label>
          <select id="h-estado" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <option value="Bueno">Bueno</option>
            <option value="Regular">Regular</option>
            <option value="Roto">Roto</option>
            <option value="En reparación">En reparación</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Ubicación *</label>
          <select id="h-ubicacion" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <option value="Taller">Taller</option>
            <option value="Obra">Obra</option>
            <option value="Depósito">Depósito</option>
            <option value="Vehículo asignado">Vehículo asignado</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fecha Últ. Control</label>
          <input type="date" id="h-ult-control" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Próximo Control</label>
          <input type="date" id="h-prox-control" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </div>
      </div>
      <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
        <button type="button" onclick="closeToolModal()" class="px-4 py-2 text-gray-600 hover:text-gray-800 text-sm">Cancelar</button>
        <button type="submit" class="px-6 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition">Guardar</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/tools.js"></script>
<%- include('partials/footer') %>
