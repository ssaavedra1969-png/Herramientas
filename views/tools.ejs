<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('partials/sidebar', { page: 'tools' }) %>
  <div class="flex-1 flex flex-col overflow-hidden">
    <div class="lg:hidden header-glass text-[#F1F3F8] p-3 flex items-center justify-between">
      <button id="mobile-menu-btn" class="p-1 rounded hover:bg-[#FF6B35]/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-gradient-primary">Grupo Falpat SRL</span>
      <span class="w-8 h-8 bg-gradient-to-br from-[#FF6B35] to-[#FF3366] rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg"><%= (currentUserData?.displayName || 'U').charAt(0).toUpperCase() %></span>
    </div>
    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <h1 class="text-2xl font-bold text-gradient-primary">Herramientas</h1>
          <p class="text-[#8E94A8] text-sm">Inventario de herramientas</p>
        </div>
        <% if (currentUserData?.role === 'Admin') { %>
        <button onclick="openToolModal()" class="btn-primary text-sm flex items-center gap-1 px-4 py-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Nueva
        </button>
        <% } %>
      </div>

      <div class="mt-6 glass-card rounded-xl">
        <div class="p-4 border-b border-[#FF6B35]/10 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between">
          <div class="flex gap-2 flex-wrap">
            <input type="text" id="search-herramienta" placeholder="Buscar por nombre o código..." class="px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm w-64 text-[#F1F3F8] placeholder-[#5C6378] input-neon">
            <select id="filter-estado-herramienta" class="px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
              <option value="" class="bg-[#0B0E17]">Todos los estados</option>
              <option value="Bueno" class="bg-[#0B0E17]">Bueno</option>
              <option value="Regular" class="bg-[#0B0E17]">Regular</option>
              <option value="Roto" class="bg-[#0B0E17]">Roto</option>
              <option value="En reparación" class="bg-[#0B0E17]">En reparación</option>
            </select>
          </div>
        </div>
        <div class="table-container p-4">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-[#8E94A8] border-b border-[#FF6B35]/10">
                <th class="pb-3 font-medium">Código</th>
                <th class="pb-3 font-medium">Nombre</th>
                <th class="pb-3 font-medium">Tipo</th>
                <th class="pb-3 font-medium">Estado</th>
                <th class="pb-3 font-medium">Ubicación</th>
                <th class="pb-3 font-medium">Últ. Control</th>
                <th class="pb-3 font-medium">Próx. Control</th>
                <th class="pb-3 font-medium no-print">Acciones</th>
              </tr>
            </thead>
            <tbody id="tools-table-body">
              <tr><td colspan="8" class="text-center py-8 text-[#5C6378]">Cargando herramientas...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/mobile-menu', { page: 'tools' }) %>

<div id="modal-herramienta" class="fixed inset-0 z-50 hidden modal-backdrop flex items-center justify-center p-4">
  <div class="glass-card rounded-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto modal-content">
    <div class="flex items-center justify-between p-6 border-b border-[#FF6B35]/10 sticky top-0 z-10" style="background: #141e2d;">
      <h3 class="text-lg font-bold text-[#F1F3F8]" id="modal-herramienta-title">Nueva Herramienta</h3>
      <button onclick="closeToolModal()" class="text-[#8E94A8] hover:text-[#F1F3F8] transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form id="form-herramienta" class="p-6 space-y-4">
      <input type="hidden" id="herramienta-id">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Nombre *</label>
          <input type="text" id="h-nombre" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="Taladro">
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Código Interno *</label>
          <input type="text" id="h-codigo" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] placeholder-[#5C6378] input-neon" placeholder="TAL-001">
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Tipo *</label>
          <select id="h-tipo" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
            <option value="Eléctrica" class="bg-[#0B0E17]">Eléctrica</option>
            <option value="Neumática" class="bg-[#0B0E17]">Neumática</option>
            <option value="Manual" class="bg-[#0B0E17]">Manual</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Estado *</label>
          <select id="h-estado" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
            <option value="Bueno" class="bg-[#0B0E17]">Bueno</option>
            <option value="Regular" class="bg-[#0B0E17]">Regular</option>
            <option value="Roto" class="bg-[#0B0E17]">Roto</option>
            <option value="En reparación" class="bg-[#0B0E17]">En reparación</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Ubicación *</label>
          <select id="h-ubicacion" required class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
            <option value="Taller" class="bg-[#0B0E17]">Taller</option>
            <option value="Obra" class="bg-[#0B0E17]">Obra</option>
            <option value="Depósito" class="bg-[#0B0E17]">Depósito</option>
            <option value="Vehículo asignado" class="bg-[#0B0E17]">Vehículo asignado</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Fecha Últ. Control</label>
          <input type="date" id="h-ult-control" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Próximo Control</label>
          <input type="date" id="h-prox-control" class="w-full px-3 py-2 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-sm text-[#F1F3F8] input-neon">
        </div>
      </div>
      <div class="flex justify-end gap-3 pt-4 border-t border-[#FF6B35]/10">
        <button type="button" onclick="closeToolModal()" class="px-4 py-2 text-[#8E94A8] hover:text-[#F1F3F8] text-sm transition-colors">Cancelar</button>
        <button type="submit" class="btn-primary text-sm px-6 py-2">Guardar</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/tools.js"></script>
<%- include('partials/footer') %>
