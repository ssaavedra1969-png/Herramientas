<%- include('partials/head') %>
<div class="min-h-screen flex items-center justify-center p-4 relative z-10">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full mb-4 glass-card shadow-lg">
        <svg class="w-10 h-10 text-[#FF6B35]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-gradient-primary neon-text-gold">Grupo Falpat SRL</h1>
      <p class="text-[#8E94A8] mt-1">Control de Mantenimiento</p>
    </div>

    <div class="glass-card rounded-2xl p-8">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 px-4 py-3 rounded-lg border border-red-500/30 bg-red-900/50 text-red-400 text-sm text-center"><%= error %></div>
      <% } %>
      <div class="flex mb-6 bg-[#0B0E17]/50 rounded-lg p-1 border border-[#FF6B35]/10">
        <button id="tab-login" class="flex-1 py-2 text-center rounded-md text-sm font-medium transition text-[#FF6B35] bg-[#FF6B35]/10 shadow-sm">Iniciar Sesión</button>
        <button id="tab-register" class="flex-1 py-2 text-center rounded-md text-sm font-medium transition text-[#8E94A8] hover:text-[#F1F3F8]">Registrarse</button>
      </div>

      <form id="login-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Email</label>
          <input type="email" id="login-email" required class="input-neon w-full px-4 py-2.5 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-[#F1F3F8] placeholder-[#5C6378] focus:border-[#FF6B35] focus:ring-2 focus:ring-[#FF6B35]/20" placeholder="correo@ejemplo.com">
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Contraseña</label>
          <input type="password" id="login-password" required class="input-neon w-full px-4 py-2.5 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-[#F1F3F8] placeholder-[#5C6378] focus:border-[#FF6B35] focus:ring-2 focus:ring-[#FF6B35]/20" placeholder="••••••••">
        </div>
        <button type="button" id="btn-login-submit" class="btn-primary w-full text-center py-2.5">Ingresar</button>
        <p id="login-error" class="text-red-400 text-sm text-center hidden"></p>
      </form>

      <form id="register-form" class="space-y-4 hidden">
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Nombre completo</label>
          <input type="text" id="reg-name" required class="input-neon w-full px-4 py-2.5 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-[#F1F3F8] placeholder-[#5C6378] focus:border-[#FF6B35] focus:ring-2 focus:ring-[#FF6B35]/20" placeholder="Juan Pérez">
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Email</label>
          <input type="email" id="reg-email" required class="input-neon w-full px-4 py-2.5 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-[#F1F3F8] placeholder-[#5C6378] focus:border-[#FF6B35] focus:ring-2 focus:ring-[#FF6B35]/20" placeholder="correo@ejemplo.com">
        </div>
        <div>
          <label class="block text-sm font-medium text-[#8E94A8] mb-1">Contraseña</label>
          <input type="password" id="reg-password" required minlength="6" class="input-neon w-full px-4 py-2.5 bg-[#0B0E17]/50 border border-[#FF6B35]/20 rounded-lg text-[#F1F3F8] placeholder-[#5C6378] focus:border-[#FF6B35] focus:ring-2 focus:ring-[#FF6B35]/20" placeholder="Mínimo 6 caracteres">
        </div>
        <button type="button" id="btn-register-submit" class="w-full bg-gradient-to-r from-[#FF6B35] to-[#FFD700] text-[#0B0E17] font-bold py-2.5 rounded-lg hover:shadow-lg hover:shadow-[#FF6B35]/20 transition-all duration-300 transform hover:scale-[1.02]">Crear cuenta</button>
        <p id="register-error" class="text-red-400 text-sm text-center hidden"></p>
      </form>


    </div>
    <p class="text-center text-[#5C6378] text-xs mt-6">&copy; 2024 Grupo Falpat SRL</p>
  </div>
</div>

<%- include('partials/footer') %>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabLogin = document.getElementById('tab-login');
  const tabRegister = document.getElementById('tab-register');
  const loginForm = document.getElementById('login-form');
  const registerForm = document.getElementById('register-form');
  const loginError = document.getElementById('login-error');
  const registerError = document.getElementById('register-error');

  if (!tabLogin || !loginForm) return;

  function showLoginError(msg) {
    loginError.textContent = msg;
    loginError.classList.remove('hidden');
  }

  function showRegisterError(msg) {
    registerError.textContent = msg;
    registerError.classList.remove('hidden');
  }

  tabLogin.addEventListener('click', () => {
    tabLogin.classList.add('text-[#FF6B35]', 'bg-[#FF6B35]/10');
    tabRegister.classList.remove('text-[#FF6B35]', 'bg-[#FF6B35]/10');
    tabRegister.classList.add('text-[#8E94A8]');
    loginForm.classList.remove('hidden');
    registerForm.classList.add('hidden');
    loginError.classList.add('hidden');
    registerError.classList.add('hidden');
  });

  tabRegister.addEventListener('click', () => {
    tabRegister.classList.add('text-[#FF6B35]', 'bg-[#FF6B35]/10');
    tabLogin.classList.remove('text-[#FF6B35]', 'bg-[#FF6B35]/10');
    tabLogin.classList.add('text-[#8E94A8]');
    registerForm.classList.remove('hidden');
    loginForm.classList.add('hidden');
    loginError.classList.add('hidden');
    registerError.classList.add('hidden');
  });

  async function doLogin() {
    loginError.classList.add('hidden');
    if (typeof loginUser !== 'function') return showLoginError('Error al cargar la aplicación. Intente recargar la página.');
    const email = document.getElementById('login-email').value.trim();
    const pass = document.getElementById('login-password').value;
    if (!email || !email.includes('@')) return showLoginError('Ingresá un email válido.');
    if (!pass) return showLoginError('Ingresá la contraseña.');
    try {
      await loginUser(email, pass);
    } catch (e) {
      console.warn('Login error:', e.code, e.message, e);
      const msg = friendlyError(e);
      showLoginError(msg);
      if (typeof showToast === 'function') showToast(msg, 'error');
    }
  }

  async function doRegister() {
    registerError.classList.add('hidden');
    if (typeof registerUser !== 'function') return showRegisterError('Error al cargar la aplicación. Intente recargar la página.');
    try {
      await registerUser(document.getElementById('reg-email').value.trim(), document.getElementById('reg-password').value, document.getElementById('reg-name').value.trim());
    } catch (e) {
      const msg = friendlyError(e);
      showRegisterError(msg);
      if (typeof showToast === 'function') showToast(msg, 'error');
    }
  }

  document.getElementById('login-email')?.addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
  document.getElementById('login-password')?.addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
  document.getElementById('reg-name')?.addEventListener('keydown', e => { if (e.key === 'Enter') doRegister(); });
  document.getElementById('reg-email')?.addEventListener('keydown', e => { if (e.key === 'Enter') doRegister(); });
  document.getElementById('reg-password')?.addEventListener('keydown', e => { if (e.key === 'Enter') doRegister(); });

  document.getElementById('btn-login-submit')?.addEventListener('click', doLogin);

  document.getElementById('btn-register-submit')?.addEventListener('click', doRegister);

  if (typeof initAuthResult === 'function') {
    initAuthResult();
  }
});
</script>
